local function ApplySkybox(name)
    local p = SkyboxPresets[name]; if not p then return end
    if p.restore then
        Sky.SkyboxBk=OriginalSky.SkyboxBk; Sky.SkyboxDn=OriginalSky.SkyboxDn
        Sky.SkyboxFt=OriginalSky.SkyboxFt; Sky.SkyboxLf=OriginalSky.SkyboxLf
        Sky.SkyboxRt=OriginalSky.SkyboxRt; Sky.SkyboxUp=OriginalSky.SkyboxUp
        Sky.StarCount=OriginalSky.StarCount; Sky.MoonAngularSize=OriginalSky.MoonAngularSize
        Sky.SunAngularSize=OriginalSky.SunAngularSize
    else
        if p.StarCount       then Sky.StarCount=p.StarCount             end
        if p.MoonAngularSize then Sky.MoonAngularSize=p.MoonAngularSize end
        if p.SunAngularSize  then Sky.SunAngularSize=p.SunAngularSize   end
    end
    if p.Brightness     then Lighting.Brightness=p.Brightness         end
    if p.ClockTime      then Lighting.ClockTime=p.ClockTime           end
    if p.Ambient        then Lighting.Ambient=p.Ambient               end
    if p.OutdoorAmbient then Lighting.OutdoorAmbient=p.OutdoorAmbient end
    if p.FogColor       then Lighting.FogColor=p.FogColor             end
    if p.FogEnd         then Lighting.FogEnd=p.FogEnd                 end
end

