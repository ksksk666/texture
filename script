local function ClearContent()
    CloseDropdown()
    _FPS_Labels  = {}
    _Ping_Labels = {}
    for _, c in ipairs(ContentScroll:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
    end
    ContentScroll.CanvasPosition=Vector2.new(0,0)
end

local function SwitchTab(id)
    if ActiveTab==id then return end
    ActiveTab=id
    ClearContent()
    for n, btn in pairs(TabButtons) do
        if n==id then
            btn.BackgroundTransparency=0
            Tween(btn,{BackgroundColor3=T.TabActive,TextColor3=T.Text})
        else
            Tween(btn,{BackgroundColor3=Color3.fromRGB(0,0,0),TextColor3=T.TextMuted})
            btn.BackgroundTransparency=1
        end
    end
    if TabContent[id] then TabContent[id]() end
end

for _, tab in ipairs(TABS) do
    local btn=New("TextButton",{
        Text=tab.icon.."  "..tab.label,
        Size=UDim2.new(1,0,0,32),
        BackgroundColor3=Color3.fromRGB(0,0,0), BackgroundTransparency=1,
        TextColor3=T.TextMuted,
        Font=Enum.Font.GothamSemibold, TextSize=12,
        BorderSizePixel=0, AutoButtonColor=false,
        TextXAlignment=Enum.TextXAlignment.Left,
    },SideScroll)
    Rnd(7,btn)
    Pad(0,0,10,8,btn)
    btn.MouseEnter:Connect(function()
        if ActiveTab~=tab.id then
            btn.BackgroundTransparency=0
            Tween(btn,{BackgroundColor3=Color3.fromRGB(25,25,25),TextColor3=T.TextSub})
        end
    end)
    btn.MouseLeave:Connect(function()
        if ActiveTab~=tab.id then
            Tween(btn,{BackgroundColor3=Color3.fromRGB(0,0,0)})
            btn.BackgroundTransparency=1
        end
    end)
    btn.MouseButton1Click:Connect(function() SwitchTab(tab.id) end)
    TabButtons[tab.id]=btn
    TabContent[tab.id]=function() end
end

