local function ApplySkybox(name)
    local p = SkyboxPresets[name]; if not p then return end
    if p.restore then
        Sky.SkyboxBk=OrigSky.Bk; Sky.SkyboxDn=OrigSky.Dn; Sky.SkyboxFt=OrigSky.Ft
        Sky.SkyboxLf=OrigSky.Lf; Sky.SkyboxRt=OrigSky.Rt; Sky.SkyboxUp=OrigSky.Up
        Sky.StarCount=OrigSky.Stars; Sky.MoonAngularSize=OrigSky.Moon; Sky.SunAngularSize=OrigSky.Sun
    else
        if p.Stars then Sky.StarCount=p.Stars end
        if p.Moon  then Sky.MoonAngularSize=p.Moon end
        if p.Sun   then Sky.SunAngularSize=p.Sun end
    end
    local ti = TweenInfo.new(S.WeatherTransSpeed or 1, Enum.EasingStyle.Quad)
    local props = {}
    if p.b  then props.Brightness=p.b end
    if p.t  then props.ClockTime=p.t end
    if p.a  then props.Ambient=p.a end
    if p.oa then props.OutdoorAmbient=p.oa end
    if p.fc then props.FogColor=p.fc end
    if p.fe then props.FogEnd=p.fe end
    TweenSvc:Create(Lighting, ti, props):Play()
    Log("Skybox: " .. name)
end

