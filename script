local rainSpawnTimer=0
local function spawnSplash(px,py)
    for i=1,MAX_SPLASHES do
        if not splashData[i].active then
            splashData[i]={active=true,x=px,y=py,t=0,maxT=0.32,r=0}
            splashFrames[i].Visible=true; return
        end
    end
end

local function resetDrop(i)
    local sw=RainGui.AbsoluteSize.X; local sh=RainGui.AbsoluteSize.Y
    local d=dropData[i]
    local windAngleRad=math.rad(S.WindDir or 0)
    local windMag=(S.WindStr or 10)/80
    if rainType=="snow" then
        d.len=math.random(3,7); d.thick=math.random(3,6)
        d.vy=sh*(0.06+math.random()*0.08)
        d.vx=(math.cos(windAngleRad)*windMag+(math.random()-0.5)*0.03)*sw
        d.alpha=0.25+math.random()*0.3
        dropData[i]={active=true,x=math.random(-sw//4,sw+sw//4),y=-d.len,vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    elseif rainType=="sand" then
        d.len=math.random(4,10); d.thick=math.random(2,5)
        d.vy=sh*(0.08+math.random()*0.05)
        d.vx=(math.cos(windAngleRad)*windMag*3+0.15+math.random()*0.1)*sw
        d.alpha=0.30+math.random()*0.25
        dropData[i]={active=true,x=-sw//4,y=math.random(0,sh),vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    else
        local sm=(S.Weather=="Blizzard" or S.Weather=="Thunderstorm" or S.Weather=="Hurricane" or S.Weather=="Purple Storm") and 1.4 or 1.0
        d.len=math.random(10,22); d.thick=math.random(10,16)/10
        d.vy=sh*(0.18+math.random()*0.25)*sm
        d.vx=(math.cos(windAngleRad)*windMag+(math.random()-0.5)*0.02)*sw
        d.alpha=0.2+math.random()*0.25
        dropData[i]={active=true,x=math.random(-sw//4,sw+sw//4),y=-d.len,vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    end
end

local function updateRain(dt)
    local sw=RainGui.AbsoluteSize.X; local sh=RainGui.AbsoluteSize.Y
    if sw==0 or sh==0 then return end
    local spawnRate=rainType=="snow" and 0.045 or rainType=="sand" and 0.025 or 0.018
    local density=math.floor(S.Density or 5)
    local toSpawn=rainType=="snow" and math.max(1,density-2) or rainType=="sand" and density or density+2
    rainSpawnTimer=rainSpawnTimer+dt
    if rainSpawnTimer>=spawnRate then
        rainSpawnTimer=0
        local spawned=0
        for i=1,MAX_DROPS do
            if not dropData[i].active and spawned<toSpawn then
                resetDrop(i); spawned=spawned+1
            end
        end
    end
    local windAngleRad=math.rad(S.WindDir or 0)
    local windMag=(S.WindStr or 10)/80
    local angleDeg=math.deg(math.atan2(math.cos(windAngleRad)*windMag*sw,(S.Density or 5)*8))
    -- Determine drop color from weather
    local dropColor=Color3.fromRGB(180,215,255)
    if S.Weather=="Acid Rain" then dropColor=Color3.fromRGB(120,220,80)
    elseif S.Weather=="Purple Storm" then dropColor=Color3.fromRGB(180,130,255)
    elseif rainType=="sand" then dropColor=Color3.fromRGB(210,178,118) end

    for i=1,MAX_DROPS do
        local d=dropData[i]
        if d.active then
            d.x=d.x+d.vx*dt; d.y=d.y+d.vy*dt
            local f=dropFrames[i]
            if d.y>sh+40 or d.x>sw*1.3 or d.x<-sw*0.3 then
                d.active=false; f.Visible=false
                if d.y>=sh-20 and d.y<=sh+40 and rainType=="rain" then spawnSplash(d.x,sh-2) end
            else
                f.Visible=true
                if rainType=="snow" then
                    f.Size=UDim2.new(0,d.thick,0,d.thick)
                    f.Position=UDim2.new(0,math.floor(d.x-d.thick/2),0,math.floor(d.y-d.thick/2))
                    f.Rotation=0; f.BackgroundColor3=Color3.fromRGB(225,238,255); f.BackgroundTransparency=1-d.alpha
                elseif rainType=="sand" then
                    f.Size=UDim2.new(0,d.len,0,d.thick)
                    f.Position=UDim2.new(0,math.floor(d.x),0,math.floor(d.y-d.thick/2))
                    f.Rotation=0; f.BackgroundColor3=dropColor; f.BackgroundTransparency=1-d.alpha
                else
                    f.Size=UDim2.new(0,math.floor(d.thick*10)/10,0,d.len)
                    f.Position=UDim2.new(0,math.floor(d.x),0,math.floor(d.y))
                    f.Rotation=angleDeg*0.6; f.BackgroundColor3=dropColor; f.BackgroundTransparency=1-d.alpha
                end
            end
        else dropFrames[i].Visible=false end
    end
    for i=1,MAX_SPLASHES do
        local sd=splashData[i]
        if sd.active then
            sd.t=sd.t+dt
            local progress=sd.t/sd.maxT
            if progress>=1 then sd.active=false; splashFrames[i].Visible=false
            else
                local eased=1-(1-progress)^2
                local radius=eased*14; local alpha=(1-progress)*0.8
                local sf=splashFrames[i]
                sf.Size=UDim2.new(0,radius*2,0,radius*0.45)
                sf.Position=UDim2.new(0,math.floor(sd.x-radius),0,math.floor(sd.y-radius*0.22))
                sf.Visible=true
                local inner=sf:FindFirstChildOfClass("Frame")
                if inner then
                    local stroke=inner:FindFirstChildOfClass("UIStroke")
                    if stroke then stroke.Transparency=1-alpha end
                    local dot=inner:FindFirstChildOfClass("Frame")
                    if dot then dot.BackgroundTransparency=1-alpha*0.6 end
                end
            end
        end
    end
end

local function clearAllRain()
    rainActive=false; rainType="none"
    for i=1,MAX_DROPS do dropData[i].active=false; dropFrames[i].Visible=false end
    for i=1,MAX_SPLASHES do splashData[i].active=false; splashFrames[i].Visible=false end
end

