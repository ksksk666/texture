local function ApplyWeather(name)
    for _, o in ipairs(EffFX:GetChildren()) do
        if not o.Name:find("Puddle") then o:Destroy() end
    end
    S.Weather = name
    S.Thunder = false
    rainActive = false
    rainType   = "none"
    rainColor  = Color3.fromRGB(178,212,255)
    local w = WeatherData[name]
    if not w then
        local spd = S.WeatherTransSpeed or 1
        local ti = TweenInfo.new(spd, Enum.EasingStyle.Quad)
        TweenSvc:Create(Lighting, ti, {
            ClockTime=OrigLight.ClockTime, Brightness=OrigLight.Brightness,
            Ambient=OrigLight.Ambient, OutdoorAmbient=OrigLight.OutdoorAmbient,
            FogEnd=OrigLight.FogEnd, FogStart=OrigLight.FogStart, FogColor=OrigLight.FogColor,
        }):Play()
        if S.RainSoundOn then
            TweenSvc:Create(RainSound,TweenInfo.new(1),{Volume=0}):Play()
        end
        Log("Weather cleared")
        return
    end
    local spd = S.WeatherTransSpeed or 1
    local ti = TweenInfo.new(spd, Enum.EasingStyle.Quad)
    TweenSvc:Create(Lighting, ti, {
        ClockTime=w.t or 12, Brightness=w.b or 1,
        Ambient=w.a or Lighting.Ambient, OutdoorAmbient=w.oa or Lighting.OutdoorAmbient,
        FogEnd=w.fe or 1000, FogStart=w.fs or 0, FogColor=w.fc or Lighting.FogColor,
    }):Play()
    if w.stars then Sky.StarCount = w.stars end
    S.Thunder = w.thunder == true
    if w.rain then
        rainActive = true
        rainType   = w.rain
        if w.rain == "acid" then rainColor = Color3.fromRGB(100,220,80) end
        if S.RainSoundOn then
            TweenSvc:Create(RainSound,TweenInfo.new(1),{Volume=S.RainSoundVol}):Play()
        end
    end
    Log("Weather set: " .. name)
end

