        Font=Enum.Font.Gotham, TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true,
    }, notif)
    -- Slide in
    tw(notif,{Position=UDim2.new(1,-268,0,0)},0.25)
    if S.NotifSounds then
        pcall(function()
            local s=Instance.new("Sound",workspace)
            s.SoundId="rbxassetid://9117434120"; s.Volume=0.3; s:Play()
            Debris:AddItem(s,2)
        end)
    end
    table.insert(NotifStack, notif)
    task.delay(duration, function()
        pcall(function()
            tw(notif,{Position=UDim2.new(1,10,0,0)},0.2)
            task.delay(0.25,function()
                pcall(function() notif:Destroy() end)
                for i=#NotifStack,1,-1 do
                    if NotifStack[i]==notif then table.remove(NotifStack,i); break end
                end
            end)
        end)
    end)
end

