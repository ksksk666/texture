        TextColor3=C.Text, PlaceholderText="Enter command...", PlaceholderColor3=C.TextM,
        Font=Enum.Font.Gotham, TextSize=11, ClearTextOnFocus=false, TextXAlignment=Enum.TextXAlignment.Left,
    },cmdBar)
    local cmdRun=mk("TextButton",{
        Text="Run", Size=UDim2.new(0,60,0,26), Position=UDim2.new(1,-60,0.5,-13),
        BackgroundColor3=Color3.fromRGB(36,36,36), TextColor3=C.Text,
        Font=Enum.Font.GothamSemibold, TextSize=11, BorderSizePixel=0,
    },cmdBar)
    mk("UICorner",{CornerRadius=UDim.new(0,6)},cmdRun)
    local function runCmd(raw)
        local parts={}
        for word in raw:gmatch("%S+") do table.insert(parts,word) end
        if #parts==0 then return end
        local cmd=parts[1]:lower():gsub("^:","")
        if cmd=="fly" then S.Fly=not S.Fly; Notify("Fly: "..(S.Fly and "ON" or "OFF"),C.Green)
        elseif cmd=="noclip" then S.Noclip=not S.Noclip; Notify("Noclip: "..(S.Noclip and "ON" or "OFF"),C.Green)
        elseif cmd=="god" then S.GodMode=not S.GodMode; Notify("God: "..(S.GodMode and "ON" or "OFF"),C.Green)
        elseif cmd=="speed" then local v=tonumber(parts[2]); if v then S.WalkSpeed=v; local h=LP.Character and LP.Character:FindFirstChild("Humanoid"); if h then h.WalkSpeed=v end; Notify("Speed: "..v,C.Green) end
        elseif cmd=="jump" then local v=tonumber(parts[2]); if v then local h=LP.Character and LP.Character:FindFirstChild("Humanoid"); if h then h.JumpPower=v end; Notify("Jump: "..v,C.Green) end
        elseif cmd=="weather" then local wn=parts[2]; if wn then ApplyWeather(wn); Notify("Weather: "..wn,C.Blue) end
        elseif cmd=="clear" then ApplyWeather("None"); clearAllRain(); Notify("Weather cleared",C.AccentD)
        elseif cmd=="reset" then local h=LP.Character and LP.Character:FindFirstChild("Humanoid"); if h then h.Health=0 end
        else Notify("Unknown command: "..cmd,C.Orange) end
        Log("CMD: "..raw)
    end
    cmdRun.MouseButton1Click:Connect(function() runCmd(cmdInput.Text); cmdInput.Text="" end)
    cmdInput.FocusLost:Connect(function(enter) if enter then runCmd(cmdInput.Text); cmdInput.Text="" end end)
end

