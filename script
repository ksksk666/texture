local function Dropdown(p,label,opts,default,cb)
    local selected=default or opts[1]; local lo=nextLO(p)
    local card=mk("Frame",{Size=UDim2.new(1,0,0,40),BackgroundColor3=C.Card,BorderSizePixel=0,LayoutOrder=lo},p)
    mk("UICorner",{CornerRadius=UDim.new(0,8)},card)
    mk("UIStroke",{Color=C.Border,Thickness=1},card)
    mk("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12)},card)
    mk("TextLabel",{Text=label,Size=UDim2.new(0.42,0,1,0),BackgroundTransparency=1,TextColor3=C.TextS,
        Font=Enum.Font.Gotham,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left},card)
    local selRow=mk("Frame",{Size=UDim2.new(0.58,-4,0,26),Position=UDim2.new(0.42,0,0.5,-13),
        BackgroundColor3=C.Input,BorderSizePixel=0},card)
    mk("UICorner",{CornerRadius=UDim.new(0,6)},selRow)
    mk("UIStroke",{Color=C.Border,Thickness=1},selRow)
    mk("UIPadding",{PaddingLeft=UDim.new(0,9),PaddingRight=UDim.new(0,8)},selRow)
    local selLbl=mk("TextLabel",{Text=selected,Size=UDim2.new(1,-14,1,0),BackgroundTransparency=1,
        TextColor3=C.Text,Font=Enum.Font.GothamSemibold,TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left},selRow)
    mk("TextLabel",{Text="▾",Size=UDim2.new(0,13,1,0),Position=UDim2.new(1,-13,0,0),
        BackgroundTransparency=1,TextColor3=C.TextM,Font=Enum.Font.GothamBold,TextSize=10},selRow)
    local hit=mk("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=5},card)
    hit.MouseButton1Click:Connect(function()
        if DropMenu.Visible and AD.selLbl==selLbl then closeDrop()
        else openDrop(card,opts,selLbl,function(v) selected=v; pcall(cb,v) end) end
    end)
    card.MouseEnter:Connect(function() tw(card,{BackgroundColor3=C.CardH}) end)
    card.MouseLeave:Connect(function() tw(card,{BackgroundColor3=C.Card}) end)
    return {SetValue=function(v) selected=v; selLbl.Text=v end}
end

