local function Toggle(label, default, callback)
    local state=default or false
    local card=New("Frame",{
        Size=UDim2.new(1,0,0,40),
        BackgroundColor3=T.Card, BorderSizePixel=0,
        LayoutOrder=nextOrder(),
    },ContentScroll)
    Rnd(8,card); Stroke(T.Border,1,card); Pad(0,0,12,12,card)

    New("TextLabel",{
        Text=label, Size=UDim2.new(1,-58,1,0),
        BackgroundTransparency=1,
        TextColor3=T.Text, Font=Enum.Font.Gotham, TextSize=12,
        TextXAlignment=Enum.TextXAlignment.Left,
    },card)

    local track=New("Frame",{
        Size=UDim2.new(0,40,0,20), Position=UDim2.new(1,-44,0.5,-10),
        BackgroundColor3=state and T.Accent or T.ToggleOff, BorderSizePixel=0,
    },card)
    Rnd(10,track)

    local knob=New("Frame",{
        Size=UDim2.new(0,14,0,14),
        Position=state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
        BackgroundColor3=state and T.BG or T.TextMuted, BorderSizePixel=0,
    },track)
    Rnd(7,knob)

    local function Update(s)
        state=s
        Tween(track,{BackgroundColor3=s and T.Accent or T.ToggleOff})
        Tween(knob,{Position=s and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
                    BackgroundColor3=s and T.BG or T.TextMuted})
        callback(s)
    end

    local hitbox=New("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=5},card)
    hitbox.MouseButton1Click:Connect(function() Update(not state) end)
    card.MouseEnter:Connect(function() Tween(card,{BackgroundColor3=T.CardHov}) end)
    card.MouseLeave:Connect(function() Tween(card,{BackgroundColor3=T.Card}) end)

    return {SetValue=function(v) Update(v) end, GetValue=function() return state end}
end

local function Slider(label, mn, mx, default, inc, callback)
    local val=default or mn
    local card=New("Frame",{
        Size=UDim2.new(1,0,0,58),
        BackgroundColor3=T.Card, BorderSizePixel=0,
        LayoutOrder=nextOrder(),
    },ContentScroll)
    Rnd(8,card); Stroke(T.Border,1,card); Pad(8,9,12,12,card); VList(5,card)

    local topRow=New("Frame",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1},card)
    New("TextLabel",{
        Text=label, Size=UDim2.new(0.75,0,1,0),
        BackgroundTransparency=1,
        TextColor3=T.TextSub, Font=Enum.Font.Gotham, TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,
    },topRow)
    local badge=New("Frame",{
        Size=UDim2.new(0,48,0,14), Position=UDim2.new(1,-48,0,0),
        BackgroundColor3=Color3.fromRGB(22,22,22), BorderSizePixel=0,
    },topRow)
    Rnd(4,badge)
    local valLbl=New("TextLabel",{
        Text=tostring(val), Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
        TextColor3=T.Text, Font=Enum.Font.GothamBold, TextSize=10,
        TextXAlignment=Enum.TextXAlignment.Center,
    },badge)

    local trackBG=New("Frame",{
        Size=UDim2.new(1,0,0,5), BackgroundColor3=T.SliderBG, BorderSizePixel=0,
    },card)
    Rnd(3,trackBG)
    local fill=New("Frame",{
        Size=UDim2.new((val-mn)/(mx-mn),0,1,0),
        BackgroundColor3=T.Accent, BorderSizePixel=0,
    },trackBG)
    Rnd(3,fill)
    local ratio0=(val-mn)/(mx-mn)
    local thumb=New("Frame",{
        Size=UDim2.new(0,11,0,11), Position=UDim2.new(ratio0,-5.5,0.5,-5.5),
        BackgroundColor3=T.Text, BorderSizePixel=0, ZIndex=2,
    },trackBG)
    Rnd(6,thumb)

    local sliding=false
    local function UpdateSlider(x)
        local rel=math.clamp((x-trackBG.AbsolutePosition.X)/trackBG.AbsoluteSize.X,0,1)
        local raw=mn+(mx-mn)*rel
        local snapped=math.clamp(math.floor(raw/inc+0.5)*inc,mn,mx)
        val=snapped
        local t=(val-mn)/(mx-mn)
        fill.Size=UDim2.new(t,0,1,0)
        thumb.Position=UDim2.new(t,-5.5,0.5,-5.5)
        valLbl.Text=tostring(math.floor(val*100+0.5)/100)
        callback(val)
    end
    trackBG.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true; UpdateSlider(i.Position.X) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then UpdateSlider(i.Position.X) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
    end)
    card.MouseEnter:Connect(function() Tween(card,{BackgroundColor3=T.CardHov}) end)
    card.MouseLeave:Connect(function() Tween(card,{BackgroundColor3=T.Card}) end)
end

local function Button(label, callback, color)
    local bg=color or Color3.fromRGB(32,32,32)
    local btn=New("TextButton",{
        Text=label, Size=UDim2.new(1,0,0,36),
        BackgroundColor3=bg, TextColor3=T.Text,
        Font=Enum.Font.GothamSemibold, TextSize=12,
        BorderSizePixel=0, AutoButtonColor=false,
        LayoutOrder=nextOrder(),
    },ContentScroll)
    Rnd(8,btn)
    Stroke(T.Border,1,btn)
    btn.MouseEnter:Connect(function() Tween(btn,{BackgroundColor3=Color3.fromRGB(bg.R*255+12,bg.G*255+12,bg.B*255+12)}) end)
    btn.MouseLeave:Connect(function() Tween(btn,{BackgroundColor3=bg}) end)
    btn.MouseButton1Click:Connect(function()
        Tween(btn,{BackgroundColor3=Color3.fromRGB(60,60,60)},0.05)
        task.delay(0.08,function() Tween(btn,{BackgroundColor3=bg},0.1) end)
        callback()
    end)
    return btn
end

local function Dropdown(label, options, default, callback)
    local selected=default or options[1]
    local card=New("Frame",{
        Size=UDim2.new(1,0,0,40),
        BackgroundColor3=T.Card, BorderSizePixel=0,
        LayoutOrder=nextOrder(),
    },ContentScroll)
    Rnd(8,card); Stroke(T.Border,1,card); Pad(0,0,12,12,card)

    New("TextLabel",{
        Text=label, Size=UDim2.new(0.44,0,1,0),
        BackgroundTransparency=1,
        TextColor3=T.TextSub, Font=Enum.Font.Gotham, TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,
    },card)

    local selRow=New("Frame",{
        Size=UDim2.new(0.56,-4,0,26), Position=UDim2.new(0.44,0,0.5,-13),
        BackgroundColor3=Color3.fromRGB(22,22,22), BorderSizePixel=0,
    },card)
    Rnd(6,selRow); Stroke(T.Border,1,selRow); Pad(0,0,9,8,selRow)

    local selLbl=New("TextLabel",{
        Text=selected, Size=UDim2.new(1,-14,1,0),
        BackgroundTransparency=1,
        TextColor3=T.Text, Font=Enum.Font.GothamSemibold, TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,
    },selRow)
    New("TextLabel",{
        Text="▾", Size=UDim2.new(0,13,1,0), Position=UDim2.new(1,-13,0,0),
        BackgroundTransparency=1,
        TextColor3=T.TextMuted, Font=Enum.Font.GothamBold, TextSize=10,
    },selRow)

    local tog=New("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=5},card)
    tog.MouseButton1Click:Connect(function()
        if DropMenu.Visible and ActiveDropSelLabel==selLbl then CloseDropdown()
        else OpenDropdown(card,options,selLbl,function(v) selected=v; callback(v) end) end
    end)
    card.MouseEnter:Connect(function() Tween(card,{BackgroundColor3=T.CardHov}) end)
    card.MouseLeave:Connect(function() Tween(card,{BackgroundColor3=T.Card}) end)
end

