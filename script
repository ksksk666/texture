    local hov=Color3.new(math.min(bg.R+0.07,1),math.min(bg.G+0.07,1),math.min(bg.B+0.07,1))
    btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=hov}) end)
    btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=bg}) end)
    btn.MouseButton1Click:Connect(function()
        tw(btn,{BackgroundColor3=Color3.fromRGB(44,44,44)},0.05)
        task.delay(0.08,function() tw(btn,{BackgroundColor3=bg},0.1) end)
