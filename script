RunService.Stepped:Connect(function()
    if Noclip and LocalPlayer.Character then
        for _, p in ipairs(LocalPlayer.Character:GetDescendants()) do
            if p:IsA("BasePart") then p.CanCollide=false end
        end
    end

    if FlyEnabled and LocalPlayer.Character then
        local hum=LocalPlayer.Character:FindFirstChild("Humanoid")
        local root=LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hum and root then
            local cf=Camera.CFrame; local dir=Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir=dir+cf.LookVector    end
            if UserInputService:IsKeyDown(Enum.KeyCode.S)         then dir=dir-cf.LookVector    end
            if UserInputService:IsKeyDown(Enum.KeyCode.A)         then dir=dir-cf.RightVector   end
            if UserInputService:IsKeyDown(Enum.KeyCode.D)         then dir=dir+cf.RightVector   end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
            if dir.Magnitude>0 then dir=dir.Unit end
            root.Velocity=dir*FlySpeed; hum.PlatformStand=dir.Magnitude>0
        end
    else
        if LocalPlayer.Character then
            local hum=LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum.PlatformStand=false end
        end
    end

    -- Weather particles
    local density=math.floor(_G.WeatherDensity)
    local windX=math.cos(math.rad(_G.WindDirection))*_G.WindStrength
    local windZ=math.sin(math.rad(_G.WindDirection))*_G.WindStrength
    local camPos=Camera.CFrame.Position

    local function Drop(col,sx,sy,mat,vy,life,wm)
        local d=Instance.new("Part",FX)
        d.Size=Vector3.new(sx,sy,sx); d.Material=mat; d.Color=col
        d.CanCollide=false; d.Anchored=false; d.CastShadow=false
        d.Position=camPos+Vector3.new(math.random(-70,70),55,math.random(-70,70))
        local vel=Instance.new("BodyVelocity",d)
        vel.Velocity=Vector3.new(windX*(wm or 1)+math.random(-3,3),vy,windZ*(wm or 1)+math.random(-3,3))
        vel.MaxForce=Vector3.new(9e4,9e4,9e4); Debris:AddItem(d,life)
    end

    if WeatherType=="Rainy" then
        for _ = 1,density do Drop(Color3.fromRGB(170,200,255),0.05,1.5,Enum.Material.Glass,-120,1.2,0.5) end
    elseif WeatherType=="Stormy" or WeatherType=="Hurricane" then
        for _ = 1,density+4 do Drop(Color3.fromRGB(140,175,220),0.06,1.8,Enum.Material.Glass,-155,1.0,2.0) end
    elseif WeatherType=="Snowy" or WeatherType=="Cold" then
        for _ = 1,math.max(2,density-1) do
            local f=Instance.new("Part",FX); f.Size=Vector3.new(0.3,0.1,0.3)
            f.Material=Enum.Material.SmoothPlastic; f.Color=Color3.fromRGB(235,245,255)
            f.CanCollide=false; f.Anchored=false; f.Shape=Enum.PartType.Ball
            f.Position=camPos+Vector3.new(math.random(-70,70),45,math.random(-70,70))
            local vel=Instance.new("BodyVelocity",f)
            vel.Velocity=Vector3.new(windX*0.3+math.random(-5,5),-18,windZ*0.3+math.random(-5,5))
            vel.MaxForce=Vector3.new(9e4,9e4,9e4); Debris:AddItem(f,3)
        end
    elseif WeatherType=="Blizzard" then
        for _ = 1,density+5 do Drop(Color3.fromRGB(220,235,255),0.3,0.3,Enum.Material.SmoothPlastic,-25,2.5,3.0) end
    end
end)

-- Meteors
RunService.Stepped:Connect(function(_,dt)
    if not MeteorOn then return end
    MeteorTimer+=dt
    if MeteorTimer < 1/math.max(0.01,MeteorRate) then return end
    MeteorTimer=0
    local sp=Camera.CFrame.Position+Vector3.new(math.random(-160,160),math.random(90,160),math.random(-160,160))
    local tg=Camera.CFrame.Position+Vector3.new(math.random(-40,40),-60,math.random(-40,40))
    local dir=(tg-sp).Unit
    local m=Instance.new("Part",workspace)
    m.Size=Vector3.new(MeteorSize,MeteorSize*2.8,MeteorSize); m.Material=Enum.Material.Rock
    m.Color=_G.MeteorColor; m.CanCollide=false; m.CFrame=CFrame.new(sp,sp+dir)
    local fire=Instance.new("Fire",m); fire.Color=_G.MeteorFireColor; fire.Size=MeteorSize*3.5; fire.Heat=22
    local vel=Instance.new("BodyVelocity",m); vel.Velocity=dir*MeteorSpeed; vel.MaxForce=Vector3.new(9e4,9e4,9e4)
    local delay=(sp-tg).Magnitude/math.max(1,MeteorSpeed)+0.5
    task.delay(delay,function()
        if m and m.Parent then
            if _G.MeteorExplosions then
                local boom=Instance.new("Explosion",workspace); boom.BlastRadius=_G.MeteorExpRadius
                boom.BlastPressure=0; boom.Position=m.Position
            end
            m:Destroy()
        end
    end)
    Debris:AddItem(m,delay+1)
end)

