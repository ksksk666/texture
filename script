        local menu = Instance.new("Frame")
        menu.Size = UDim2.new(0, math.max(200, selBG.AbsoluteSize.X+40), 0, math.min(#options,8)*28+8)
        local px = selBG.AbsolutePosition.X
        local py = selBG.AbsolutePosition.Y + selBG.AbsoluteSize.Y + 4
        local ss = screenGui.AbsoluteSize
        if py + menu.AbsoluteSize.Y > ss.Y - 8 then py = selBG.AbsolutePosition.Y - menu.AbsoluteSize.Y - 4 end
        menu.Position = UDim2.new(0, px, 0, py)
        menu.BackgroundColor3 = Color3.fromRGB(14,14,14)
        menu.BorderSizePixel = 0; menu.ZIndex = 9000; menu.ClipsDescendants = true
        menu.Parent = screenGui
        Instance.new("UICorner",menu).CornerRadius = UDim.new(0,7)
        local ms = Instance.new("UIStroke"); ms.Color=THEME.Border; ms.Thickness=1; ms.Parent=menu

        local mScroll = Instance.new("ScrollingFrame")
        mScroll.Size = UDim2.new(1,0,1,0); mScroll.BackgroundTransparency = 1
        mScroll.BorderSizePixel = 0; mScroll.ScrollBarThickness = 2
        mScroll.ScrollBarImageColor3 = THEME.Border
        mScroll.CanvasSize = UDim2.new(0,0,0,0); mScroll.AutomaticCanvasSize = Enum.AutomaticSize.Y
        mScroll.ZIndex = 9001; mScroll.Parent = menu

        local mLayout = Instance.new("UIListLayout")
        mLayout.Padding = UDim.new(0,2); mLayout.SortOrder = Enum.SortOrder.LayoutOrder; mLayout.Parent = mScroll
        local mPad = Instance.new("UIPadding")
        mPad.PaddingTop=UDim.new(0,4); mPad.PaddingBottom=UDim.new(0,4)
        mPad.PaddingLeft=UDim.new(0,4); mPad.PaddingRight=UDim.new(0,4); mPad.Parent=mScroll

        for idx, opt in ipairs(options) do
            local ob = Instance.new("TextButton")
            ob.Size = UDim2.new(1,0,0,26); ob.BackgroundColor3 = Color3.fromRGB(18,18,18)
            ob.Text = "  "..opt; ob.TextColor3 = THEME.SecondaryText
            ob.Font = THEME.MainFont; ob.TextSize = 11; ob.TextXAlignment = Enum.TextXAlignment.Left
            ob.BorderSizePixel = 0; ob.AutoButtonColor = false; ob.LayoutOrder = idx; ob.ZIndex = 9002
            ob.Parent = mScroll
            Instance.new("UICorner",ob).CornerRadius = UDim.new(0,5)
            ob.MouseEnter:Connect(function() ob.BackgroundColor3=Color3.fromRGB(28,28,28); ob.TextColor3=THEME.Text end)
            ob.MouseLeave:Connect(function() ob.BackgroundColor3=Color3.fromRGB(18,18,18); ob.TextColor3=THEME.SecondaryText end)
            ob.MouseButton1Click:Connect(function()
                selected = opt; selLbl.Text = opt
                pcall(callback, opt)
                if DropMenu then DropMenu:Destroy(); DropMenu=nil; DropActive=false end
            end)
        end
        DropMenu = menu

        -- Click outside to close
        task.spawn(function()
            task.wait(0.1)
            local conn
            conn = UserInputService.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then
                    local mx,my = inp.Position.X, inp.Position.Y
                    local ap = menu.AbsolutePosition; local as = menu.AbsoluteSize
                    if mx<ap.X or mx>ap.X+as.X or my<ap.Y or my>ap.Y+as.Y then
                        if DropMenu then DropMenu:Destroy(); DropMenu=nil; DropActive=false end
                        conn:Disconnect()
                    end
                end
            end)
        end)
    end)

    f.MouseEnter:Connect(function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(18,18,18)}):Play() end)
    f.MouseLeave:Connect(function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(12,12,12)}):Play() end)
end

