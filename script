    BorderSizePixel=0, ScrollBarThickness=2,
    ScrollBarImageColor3=Color3.fromRGB(80,80,80),
    CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
    ZIndex=9001,
},DropMenu)
VList(1,DropScroll)
Pad(4,4,4,4,DropScroll)

local ActiveDropCallback = nil
local ActiveDropSelLabel = nil

local function CloseDropdown()
    DropMenu.Visible=false; ActiveDropCallback=nil; ActiveDropSelLabel=nil
    for _, c in ipairs(DropScroll:GetChildren()) do
        if not c:IsA("UIListLayout") and not c:IsA("UIPadding") then c:Destroy() end
    end
end

ScreenGui.InputBegan:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1 and DropMenu.Visible then
        local mx,my=inp.Position.X,inp.Position.Y
        local dx,dy=DropMenu.AbsolutePosition.X,DropMenu.AbsolutePosition.Y
        local dw,dh=DropMenu.AbsoluteSize.X,DropMenu.AbsoluteSize.Y
        if mx<dx or mx>dx+dw or my<dy or my>dy+dh then CloseDropdown() end
    end
end)

local function OpenDropdown(triggerFrame, options, selLabel, callback)
    CloseDropdown()
    ActiveDropSelLabel=selLabel; ActiveDropCallback=callback
    for _, opt in ipairs(options) do
        local btn=New("TextButton",{
            Text="  "..opt,
            Size=UDim2.new(1,0,0,26),
            BackgroundColor3=Color3.fromRGB(22,22,22),
            TextColor3=T.TextSub, Font=Enum.Font.Gotham, TextSize=11,
            BorderSizePixel=0, AutoButtonColor=false, ZIndex=9002,
            TextXAlignment=Enum.TextXAlignment.Left,
        },DropScroll)
        Rnd(5,btn)
        btn.MouseEnter:Connect(function() Tween(btn,{BackgroundColor3=Color3.fromRGB(35,35,35),TextColor3=T.Text}) end)
        btn.MouseLeave:Connect(function() Tween(btn,{BackgroundColor3=Color3.fromRGB(22,22,22),TextColor3=T.TextSub}) end)
        btn.MouseButton1Click:Connect(function()
            if ActiveDropSelLabel then ActiveDropSelLabel.Text=opt end
            local cb=ActiveDropCallback; CloseDropdown(); if cb then cb(opt) end
        end)
    end
    local count=math.min(#options,8)
    local menuH=count*27+10
    local menuW=math.max(170,triggerFrame.AbsoluteSize.X)
    DropMenu.Size=UDim2.new(0,menuW,0,menuH)
    local px=triggerFrame.AbsolutePosition.X
    local py=triggerFrame.AbsolutePosition.Y+triggerFrame.AbsoluteSize.Y+4
    local sw=ScreenGui.AbsoluteSize.X; local sh=ScreenGui.AbsoluteSize.Y
    if px+menuW>sw-8 then px=sw-menuW-8 end
    if py+menuH>sh-8 then py=triggerFrame.AbsolutePosition.Y-menuH-4 end
    DropMenu.Position=UDim2.new(0,px,0,py)
    DropMenu.Visible=true
end

