local function ApplyWeatherLighting(wtype)
    local w = WeatherLighting[wtype]; if not w then return end
    Lighting.ClockTime=w.t; Lighting.Brightness=w.b; Lighting.Ambient=w.a
    Lighting.OutdoorAmbient=w.oa or w.a; Lighting.FogEnd=w.fe
    Lighting.FogColor=w.fc; Lighting.FogStart=w.fs or 0
    ThunderEnabled = w.thunder == true
end

local function ClearWeatherLighting()
    Lighting.ClockTime=OriginalLighting.ClockTime; Lighting.Brightness=OriginalLighting.Brightness
    Lighting.Ambient=OriginalLighting.Ambient; Lighting.OutdoorAmbient=OriginalLighting.OutdoorAmbient
    Lighting.FogEnd=OriginalLighting.FogEnd; Lighting.FogStart=OriginalLighting.FogStart
    Lighting.FogColor=OriginalLighting.FogColor; ThunderEnabled=false
end

local function SetWeather(wtype)
    for _, o in ipairs(EffectsFolder:GetChildren()) do o:Destroy() end
    WeatherType=wtype; WeatherEnabled=(wtype~="Clear")
    if wtype=="Clear" then ClearWeatherLighting() else ApplyWeatherLighting(wtype) end
end

