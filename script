-- ============================================================
local tabFrames   = {}
local tabButtons  = {}
local currentTab  = nil

local function switchTab(name)
    if currentTab then
        tabFrames[currentTab].Visible = false
        local ob = tabButtons[currentTab]
        if ob then
            ob.TextColor3 = THEME.SecondaryText
            TweenService:Create(ob, TweenInfo.new(0.12), {BackgroundColor3 = THEME.Sidebar}):Play()
        end
    end
    currentTab = name
    if tabFrames[name] then tabFrames[name].Visible = true end
    local nb = tabButtons[name]
    if nb then
        nb.TextColor3 = THEME.Accent
        TweenService:Create(nb, TweenInfo.new(0.12), {BackgroundColor3 = THEME.Hover}):Play()
    end
end

-- Creates a tab: a full scrolling content frame
local function makeTab(name)
    local frame = Instance.new("ScrollingFrame")
    frame.Name = name.."_Tab"
    frame.Size = UDim2.new(1,0,1,0)
    frame.BackgroundTransparency = 1
    frame.BorderSizePixel = 0
    frame.ScrollBarThickness = 3
    frame.ScrollBarImageColor3 = THEME.Border
    frame.ScrollBarImageTransparency = 0.3
    frame.CanvasSize = UDim2.new(0,0,0,0)
    frame.AutomaticCanvasSize = Enum.AutomaticSize.Y
    frame.Visible = false
    frame.Parent = contentArea

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0,8)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.Parent = frame

    local pad = Instance.new("UIPadding")
    pad.PaddingTop = UDim.new(0,12); pad.PaddingBottom = UDim.new(0,16)
    pad.PaddingLeft = UDim.new(0,12); pad.PaddingRight = UDim.new(0,12)
    pad.Parent = frame

    tabFrames[name] = frame
    return frame
end

-- Creates a sidebar button for a tab
local function makeTabBtn(name, order)
    local btn = Instance.new("TextButton")
    btn.Name = name.."_Btn"
    btn.Size = UDim2.new(0,135,0,34)
    btn.BackgroundColor3 = THEME.Sidebar
    btn.Text = name:upper()
    btn.TextColor3 = THEME.SecondaryText
    btn.Font = THEME.MainFont; btn.TextSize = 12
    btn.LayoutOrder = order; btn.AutoButtonColor = false
    btn.BorderSizePixel = 0
    btn.Parent = sideScroll
    Instance.new("UICorner",btn).CornerRadius = UDim.new(0,6)

    btn.MouseEnter:Connect(function()
        if currentTab ~= name then
            TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = THEME.Hover}):Play()
        end
    end)
    btn.MouseLeave:Connect(function()
        if currentTab ~= name then
