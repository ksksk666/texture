local function resetDrop(i)
    local sw=RainGui.AbsoluteSize.X; local sh=RainGui.AbsoluteSize.Y
    local d=dropD[i]; local wRad=math.rad(S.WindDir or 0); local wMag=(S.WindStr or 10)/80
    local intMul = S.WeatherIntensity or 1
    if rainType=="snow" then
        d.len=math.random(3,7); d.thick=math.random(3,6)
        d.vy=sh*(0.06+math.random()*0.08)*intMul
        d.vx=(math.cos(wRad)*wMag+(math.random()-0.5)*0.03)*sw
        d.alpha=0.25+math.random()*0.3
        dropD[i]={active=true,x=math.random(-sw//4,sw+sw//4),y=-d.len,vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    elseif rainType=="sand" then
        d.len=math.random(5,12); d.thick=math.random(2,5)
        d.vy=sh*(0.06+math.random()*0.04)*intMul
        d.vx=(math.cos(wRad)*wMag*3+0.18+math.random()*0.1)*sw
        d.alpha=0.35+math.random()*0.25
        dropD[i]={active=true,x=-sw//4,y=math.random(0,sh),vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    else -- rain / acid
        local sp=(S.Weather=="Thunderstorm" or S.Weather=="Hurricane" or S.Weather=="Heavy Rain") and 1.5 or 1.0
        d.len=math.random(10,24); d.thick=math.random(10,18)/10
        d.vy=sh*(0.18+math.random()*0.28)*sp*intMul
        d.vx=(math.cos(wRad)*wMag+(math.random()-0.5)*0.02)*sw
        d.alpha=0.2+math.random()*0.28
        dropD[i]={active=true,x=math.random(-sw//4,sw+sw//4),y=-d.len,vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    end
end

local function updateRain(dt)
    local sw=RainGui.AbsoluteSize.X; local sh=RainGui.AbsoluteSize.Y
    if sw==0 or sh==0 then return end
    local spawnRate=rainType=="snow" and 0.045 or rainType=="sand" and 0.025 or 0.015
    local density=math.floor((S.WeatherDensity or 5)*(S.WeatherIntensity or 1))
    local toSpawn=rainType=="snow" and math.max(1,density-1) or rainType=="sand" and density or density+3
    rainSpawnT=rainSpawnT+dt
    if rainSpawnT>=spawnRate then
        rainSpawnT=0
        local spawned=0
        for i=1,MAX_DROPS do
            if not dropD[i].active and spawned<toSpawn then
                resetDrop(i); spawned=spawned+1
            end
        end
    end
    local wRad=math.rad(S.WindDir or 0); local wMag=(S.WindStr or 10)/80
    local angleDeg=math.deg(math.atan2(math.cos(wRad)*wMag*sw,(S.WeatherDensity or 5)*8))
    for i=1,MAX_DROPS do
        local d=dropD[i]
        if d.active then
            d.x=d.x+d.vx*dt; d.y=d.y+d.vy*dt
            local f=dropF[i]
            if d.y>sh+40 or d.x>sw*1.35 or d.x<-sw*0.35 then
                d.active=false; f.Visible=false
                if d.y>=sh-25 and d.y<=sh+40 and (rainType=="rain" or rainType=="acid") then
                    spawnSplash(d.x,sh-2)
                    -- Dynamic puddles
                    if S.DynamicPuddles and math.random()<0.02 then
                        local pf=Instance.new("Frame")
                        pf.Size=UDim2.new(0,math.random(20,50),0,math.random(8,18))
                        pf.Position=UDim2.new(0,math.floor(d.x-25),0,sh-math.random(10,30))
                        local pc=rainType=="acid" and Color3.fromRGB(80,220,50) or Color3.fromRGB(100,140,180)
                        pf.BackgroundColor3=pc; pf.BackgroundTransparency=0.7
                        pf.BorderSizePixel=0; pf.ZIndex=1; pf.Parent=PuddleCont
                        Instance.new("UICorner",pf).CornerRadius=UDim.new(1,0)
                        Debris:AddItem(pf, 12)
                    end
                end
            else
                f.Visible=true
                local rc=rainType=="acid" and Color3.fromRGB(100,220,80) or rainColor
                if rainType=="snow" then
                    f.Size=UDim2.new(0,d.thick,0,d.thick)
                    f.Position=UDim2.new(0,math.floor(d.x-d.thick/2),0,math.floor(d.y-d.thick/2))
                    f.Rotation=0; f.BackgroundColor3=Color3.fromRGB(225,238,255)
                    f.BackgroundTransparency=1-d.alpha
                elseif rainType=="sand" then
                    f.Size=UDim2.new(0,d.len,0,d.thick)
                    f.Position=UDim2.new(0,math.floor(d.x),0,math.floor(d.y-d.thick/2))
                    f.Rotation=0
                    f.BackgroundColor3=Color3.fromRGB(208+math.random(-4,4),175+math.random(-4,4),115+math.random(-4,4))
                    f.BackgroundTransparency=1-d.alpha
                else
                    f.Size=UDim2.new(0,math.floor(d.thick*10)/10,0,d.len)
                    f.Position=UDim2.new(0,math.floor(d.x),0,math.floor(d.y))
                    f.Rotation=angleDeg*0.65; f.BackgroundColor3=rc
                    f.BackgroundTransparency=1-d.alpha
                end
            end
        else dropF[i].Visible=false end
    end
    -- Splashes
    for i=1,MAX_SPLASH do
        local sd=splashD[i]
        if sd.active then
            sd.t=sd.t+dt; local prog=sd.t/sd.maxT
            if prog>=1 then sd.active=false; splashF[i].Visible=false
            else
                local eased=1-(1-prog)^2; local radius=eased*15; local alpha=(1-prog)*0.8
                local sf=splashF[i]
                sf.Size=UDim2.new(0,radius*2,0,radius*0.45)
                sf.Position=UDim2.new(0,math.floor(sd.x-radius),0,math.floor(sd.y-radius*0.22))
                sf.Visible=true
                local inner=sf:FindFirstChild("Frame")
                if inner then
                    local stroke=inner:FindFirstChildOfClass("UIStroke")
                    if stroke then
                        local sc=rainType=="acid" and Color3.fromRGB(80,220,60) or Color3.fromRGB(180,220,255)
                        stroke.Color=sc; stroke.Transparency=1-alpha
                    end
                end
            end
        end
    end
end

local function clearAllRain()
    rainActive=false; rainType="none"
    for i=1,MAX_DROPS do dropD[i].active=false; dropF[i].Visible=false end
    for i=1,MAX_SPLASH do splashD[i].active=false; splashF[i].Visible=false end
    for _,c in ipairs(PuddleCont:GetChildren()) do c:Destroy() end
end

