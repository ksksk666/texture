-- Heartbeat
RS.Heartbeat:Connect(function(dt)
    -- God mode
    if S.GodMode and LP.Character then
        local hum=LP.Character:FindFirstChild("Humanoid")
        if hum then hum.Health=hum.MaxHealth end
    end
    -- Slippery
    if S.Slippery and LP.Character then
        for _,part in ipairs(LP.Character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CustomPhysicalProperties=PhysicalProperties.new(0.1,0,0,0,0)
            end
        end
    end
    -- Day cycle
    if S.DayCycle then Lighting.ClockTime=(Lighting.ClockTime+S.DayCycleSpeed*dt)%24 end
    -- Skybox spin
    if S.SkyboxSpin then
        if S.SpinAxis=="Latitude" then
            Lighting.GeographicLatitude=(Lighting.GeographicLatitude+S.SpinSpeed*dt*10)%180-90
        else
            Lighting.ClockTime=(Lighting.ClockTime+S.SpinSpeed*dt*0.5)%24
        end
    end
    -- Rainbow ambient
    if S.Rainbow then
        local hue=(tick()*S.RainbowSpeed)%1
        Lighting.Ambient=Color3.fromHSV(hue,0.5,0.8)
        Lighting.OutdoorAmbient=Color3.fromHSV((hue+0.5)%1,0.5,0.8)
    end
    -- Flicker
    if S.Flicker then
        local i=S.FlickerInt
        Lighting.Brightness=math.random(math.max(1,math.floor((2-i*0.5)*10)),math.floor((2+i*0.5)*10))/10
    end
    -- Rain update
    if rainActive then updateRain(dt) end
end)

-- Ground smoke trail
local lastGP=nil
RS.Heartbeat:Connect(function()
    if S.GroundSmoke and LP.Character then
        local root=LP.Character:FindFirstChild("HumanoidRootPart")
        if root then
            if lastGP and (root.Position-lastGP).Magnitude>1.2 then
                for _=1,math.floor(S.SmokeDensity) do
                    local sp=Instance.new("Part")
                    sp.Size=Vector3.new(0.7,0.7,0.7); sp.Anchored=true; sp.CanCollide=false
                    sp.Transparency=0.5; sp.Material=Enum.Material.SmoothPlastic
                    sp.Color=Color3.fromRGB(155,155,165)
                    sp.CFrame=CFrame.new(root.Position-Vector3.new(math.random(-1,1),2.5,math.random(-1,1)))
                    sp.Parent=workspace
                    local em=Instance.new("ParticleEmitter",sp)
                    em.Rate=12; em.Lifetime=NumberRange.new(0.3,0.7)
                    em.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.5),NumberSequenceKeypoint.new(1,2.2)})
                    em.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.3),NumberSequenceKeypoint.new(1,1)})
                    em.Color=ColorSequence.new(Color3.fromRGB(165,165,175))
                    em.Speed=NumberRange.new(0.5,2); Debris:AddItem(sp,1.1)
                end
            end
            lastGP=root.Position
        end
    end
end)

-- Stepped: Noclip, Fly, Weather particles, Tornado
RS.Stepped:Connect(function()
    -- Noclip
    if S.Noclip and LP.Character then
        for _,part in ipairs(LP.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide=false end
        end
    end
    -- Fly
    if S.Fly and LP.Character then
        local hum=LP.Character:FindFirstChild("Humanoid")
        local root=LP.Character:FindFirstChild("HumanoidRootPart")
        if hum and root then
            local cf=Cam.CFrame; local dir=Vector3.new()
            if UIS:IsKeyDown(Enum.KeyCode.W)         then dir=dir+cf.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.S)         then dir=dir-cf.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A)         then dir=dir-cf.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D)         then dir=dir+cf.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
            if dir.Magnitude>0 then dir=dir.Unit end
            root.Velocity=dir*S.FlySpeed; hum.PlatformStand=dir.Magnitude>0
        end
    else
        if LP.Character then
            local hum=LP.Character:FindFirstChild("Humanoid")
            if hum then hum.PlatformStand=false end
        end
    end

    -- Tornado debris (world space particles — not screen space)
    if S.Weather=="Tornado" then
        local camPos=Cam.CFrame.Position
        local d=S.Density or 5
        for _=1,math.floor(d/2) do
            local db=Instance.new("Part")
            db.Size=Vector3.new(math.random(1,3)*0.3,math.random(1,3)*0.3,math.random(1,3)*0.3)
            db.Material=Enum.Material.SmoothPlastic
            db.Color=Color3.fromRGB(100+math.random(0,40),100+math.random(0,40),80+math.random(0,30))
            db.CanCollide=false; db.Anchored=false
            local angle=tick()*3; local radius=math.random(10,30)
            db.Position=camPos+Vector3.new(math.cos(angle)*radius+math.random(-5,5),math.random(-10,20),math.sin(angle)*radius+math.random(-5,5))
            db.Parent=EffFX
            local vel=Instance.new("BodyVelocity")
            vel.Velocity=Vector3.new(math.cos(angle+1.5)*38,math.random(5,18),math.sin(angle+1.5)*38)
            vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=db; Debris:AddItem(db,1.4)
        end
    end

    -- Volcanic ash
    if S.Weather=="Volcanic" or S.Weather=="Apocalypse" then
        local camPos=Cam.CFrame.Position
        for _=1,math.floor((S.Density or 5)*0.4) do
            local ash=Instance.new("Part")
            ash.Size=Vector3.new(0.3,0.3,0.3); ash.CanCollide=false; ash.Anchored=false
            ash.Material=Enum.Material.SmoothPlastic
            ash.Color=S.Weather=="Apocalypse" and Color3.fromRGB(60,10,5) or Color3.fromRGB(80,70,60)
            ash.Position=camPos+Vector3.new(math.random(-60,60),50,math.random(-60,60))
            ash.Parent=EffFX
            local vel=Instance.new("BodyVelocity")
            vel.Velocity=Vector3.new(math.random(-8,8),-25,math.random(-8,8))
            vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=ash; Debris:AddItem(ash,2.5)
        end
    end
end)

-- Meteor loop
RS.Stepped:Connect(function(_,dt)
    if not S.Meteor then return end
    S.MeteorTimer=S.MeteorTimer+dt
    if S.MeteorTimer<1/math.max(0.01,S.MeteorRate) then return end
    S.MeteorTimer=0
    local camPos=Cam.CFrame.Position
    local spawnPos=camPos+Vector3.new(math.random(-160,160),math.random(90,160),math.random(-160,160))
    local target=camPos+Vector3.new(math.random(-40,40),-60,math.random(-40,40))
    local dir=(target-spawnPos).Unit
    local m=Instance.new("Part")
    m.Size=Vector3.new(S.MeteorSize,S.MeteorSize*2.8,S.MeteorSize); m.Material=Enum.Material.Rock
    m.Color=S.MeteorColor; m.CanCollide=false
    m.CFrame=CFrame.new(spawnPos,spawnPos+dir); m.Parent=workspace
    local fire=Instance.new("Fire",m)
    fire.Color=S.MeteorFireColor; fire.SecondaryColor=Color3.fromRGB(255,220,80)
    fire.Size=S.MeteorSize*3.5; fire.Heat=22
    local light=Instance.new("PointLight",m); light.Brightness=6; light.Range=S.MeteorSize*12; light.Color=fire.Color
    local vel=Instance.new("BodyVelocity"); vel.Velocity=dir*S.MeteorSpeed; vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=m
    local impactDelay=(spawnPos-target).Magnitude/math.max(1,S.MeteorSpeed)+0.5
    task.delay(impactDelay,function()
        if m and m.Parent then
            if S.MeteorExplosions then
                local boom=Instance.new("Explosion"); boom.BlastRadius=S.MeteorRadius
                boom.BlastPressure=0; boom.Position=m.Position; boom.Parent=workspace
                local ob=Lighting.Brightness; Lighting.Brightness=ob+2
                task.delay(0.1,function() Lighting.Brightness=ob end)
            end
            m:Destroy()
        end
    end)
    Debris:AddItem(m,impactDelay+1)
end)

-- Thunder loop
RS.Stepped:Connect(function(_,dt)
    if not S.Thunder then S.ThunderTimer=0; return end
    S.ThunderTimer=S.ThunderTimer+dt
    local interval=S.ThunderInterval or 5
    if S.ThunderTimer<interval*(0.75+math.random()*0.5) then return end
    S.ThunderTimer=0
    local ob=Lighting.Brightness
    Lighting.Brightness=ob+5; task.delay(0.06,function() Lighting.Brightness=ob end)
    task.delay(0.16,function() Lighting.Brightness=ob+4.5 end)
    task.delay(0.24,function() Lighting.Brightness=ob end)
    task.delay(math.random(5,20)*0.1,function()
        local snd=Instance.new("Sound",workspace)
        snd.SoundId="rbxassetid://130758378"; snd.Volume=0.6+math.random()*0.4
        snd.PlaybackSpeed=0.8+math.random()*0.4; snd:Play(); Debris:AddItem(snd,5)
    end)
end)

-- ESP loop
RS.RenderStepped:Connect(function()
    for _,v in ipairs(Players:GetPlayers()) do
        if v~=LP and v.Character then
            local char=v.Character
            local hrp=char:FindFirstChild("HumanoidRootPart")
            local head=char:FindFirstChild("Head")
            local hum=char:FindFirstChild("Humanoid")
            if hrp and head then
                local needBB=S.ESPNames or S.ESPDist or S.ESPHealth
                local bb=char:FindFirstChild("WSESP")
                if needBB then
                    if not bb then
                        bb=Instance.new("BillboardGui"); bb.Name="WSESP"; bb.AlwaysOnTop=true
                        bb.Size=UDim2.new(0,140,0,76); bb.StudsOffset=Vector3.new(0,4,0)
                        bb.Adornee=head; bb.Parent=char
                    end
                    local function getOrMake(name,sz,pos,col)
                        local lbl=bb:FindFirstChild(name)
                        if not lbl then
                            lbl=Instance.new("TextLabel",bb); lbl.Name=name
                            lbl.Size=sz; lbl.Position=pos; lbl.BackgroundTransparency=1
                            lbl.TextColor3=col; lbl.TextStrokeTransparency=0
                            lbl.Font=Enum.Font.GothamBold; lbl.TextScaled=true
                        end
                        return lbl
                    end
                    local nl=getOrMake("NL",UDim2.new(1,0,0,22),UDim2.new(0,0,0,0),Color3.fromRGB(255,255,255))
                    nl.Text=S.ESPNames and v.Name or ""; nl.Visible=S.ESPNames
                    local dl=getOrMake("DL",UDim2.new(1,0,0,18),UDim2.new(0,0,0,24),Color3.fromRGB(255,220,80))
                    if S.ESPDist then
                        local myHRP=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                        dl.Text=myHRP and (math.floor((hrp.Position-myHRP.Position).Magnitude).." studs") or ""
                    end
                    dl.Visible=S.ESPDist
                    local hl2=getOrMake("HL",UDim2.new(1,0,0,18),UDim2.new(0,0,0,46),Color3.fromRGB(80,255,120))
                    if S.ESPHealth and hum then
                        local pct=hum.Health/math.max(1,hum.MaxHealth)
                        hl2.TextColor3=Color3.fromRGB(math.floor((1-pct)*255),math.floor(pct*255),50)
                        hl2.Text="HP "..math.floor(hum.Health).."/"..math.floor(hum.MaxHealth)
                    end
                    hl2.Visible=S.ESPHealth
                else
                    if bb then bb:Destroy() end
                end
                -- Highlights
                local exHL=char:FindFirstChild("WSHighlight")
                if S.ESPHighlight then
                    local hlColor=S.ESPColor
                    if S.ESPTeam then pcall(function() hlColor=v.TeamColor and Color3.fromBrickColor(v.TeamColor) or hlColor end) end
                    if not exHL then
                        local h2=Instance.new("Highlight",char); h2.Name="WSHighlight"
                        h2.FillColor=hlColor; h2.OutlineColor=Color3.fromRGB(255,255,255)
                        h2.FillTransparency=S.ESPFill; h2.OutlineTransparency=S.ESPOutline
                        h2.DepthMode=S.ChamsOnTop and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
                    else
                        exHL.FillColor=hlColor; exHL.FillTransparency=S.ESPFill
                        exHL.OutlineTransparency=S.ESPOutline
                        exHL.DepthMode=S.ChamsOnTop and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
                    end
                else
                    if exHL then exHL:Destroy() end
                end
            end
        end
    end
end)

