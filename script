local TabBtns, TabFrames, ActiveTab = {}, {}, nil

for i, tab in ipairs(TABS) do
    local btn=mk("TextButton",{
        Text=tab.icon.."  "..tab.label,
        Size=UDim2.new(1,0,0,32),
        BackgroundColor3=Color3.fromRGB(0,0,0), BackgroundTransparency=1,
        TextColor3=C.TextM, Font=Enum.Font.GothamSemibold, TextSize=12,
        BorderSizePixel=0, AutoButtonColor=false,
        TextXAlignment=Enum.TextXAlignment.Left, LayoutOrder=i,
    }, SideScroll)
    mk("UICorner",{CornerRadius=UDim.new(0,7)},btn)
    mk("UIPadding",{PaddingLeft=UDim.new(0,10)},btn)

    local scroll=mk("ScrollingFrame",{
        Size=UDim2.new(1,0,1,0), BackgroundTransparency=1, BorderSizePixel=0,
        ScrollBarThickness=3, ScrollBarImageColor3=Color3.fromRGB(48,48,48),
        ScrollBarImageTransparency=0.2,
        CanvasSize=UDim2.new(0,0,0,0), AutomaticCanvasSize=Enum.AutomaticSize.Y,
        Visible=false,
    }, ContentArea)
    mk("UIListLayout",{FillDirection=Enum.FillDirection.Vertical,
        Padding=UDim.new(0,5),SortOrder=Enum.SortOrder.LayoutOrder},scroll)
    mk("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,16),
        PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10)},scroll)

    TabBtns[tab.id]=btn; TabFrames[tab.id]=scroll

    btn.MouseEnter:Connect(function()
        if ActiveTab~=tab.id then
            btn.BackgroundTransparency=0
            tw(btn,{BackgroundColor3=Color3.fromRGB(20,20,20),TextColor3=C.TextS})
        end
    end)
    btn.MouseLeave:Connect(function()
        if ActiveTab~=tab.id then
            btn.BackgroundTransparency=1
            tw(btn,{TextColor3=C.TextM})
        end
    end)
    btn.MouseButton1Click:Connect(function()
        if ActiveTab==tab.id then return end
        if ActiveTab then
            TabFrames[ActiveTab].Visible=false
            local ob=TabBtns[ActiveTab]
            ob.BackgroundTransparency=1; tw(ob,{TextColor3=C.TextM})
        end
        ActiveTab=tab.id; scroll.Visible=true
        scroll.CanvasPosition=Vector2.new(0,0)
        btn.BackgroundTransparency=0
        tw(btn,{BackgroundColor3=C.TabA,TextColor3=C.Text})
        closeDrop()
    end)
end

