local function MakeSlider(label, mn, mx, def, inc, cb)
    local val=def or mn
    local card=N("Frame",{
        Size=UDim2.new(1,-20,0,54),
        BackgroundColor3=C.Card, BorderSizePixel=0,
    },nil)
    Corner(8,card); Border(C.Border,1,card); Pad(7,8,12,12,card)

    -- Top row
    local topRow=N("Frame",{
        Size=UDim2.new(1,0,0,13),
        BackgroundTransparency=1,
    },card)

    N("TextLabel",{
        Text=label, Size=UDim2.new(0.75,0,1,0),
        BackgroundTransparency=1,
        TextColor3=C.TextSub, Font=Enum.Font.Gotham, TextSize=11,
        TextXAlignment=Enum.TextXAlignment.Left,
    },topRow)

    local badge=N("Frame",{
        Size=UDim2.new(0,46,1,0), Position=UDim2.new(1,-46,0,0),
        BackgroundColor3=Color3.fromRGB(20,20,20), BorderSizePixel=0,
    },topRow)
    Corner(4,badge)
    local valLbl=N("TextLabel",{
        Text=tostring(val), Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,
        TextColor3=C.Text, Font=Enum.Font.GothamBold, TextSize=10,
        TextXAlignment=Enum.TextXAlignment.Center,
    },badge)

    -- Track (positioned manually inside card using absolute coords trick)
    local trackWrap=N("Frame",{
        Size=UDim2.new(1,0,0,18),
        Position=UDim2.new(0,0,0,20),
        BackgroundTransparency=1,
    },card)

    local trackBG=N("Frame",{
        Size=UDim2.new(1,0,0,5),
        Position=UDim2.new(0,0,0.5,-2.5),
        BackgroundColor3=C.SliderBG, BorderSizePixel=0,
    },trackWrap)
    Corner(3,trackBG)

    local ratio=(val-mn)/(mx-mn)
    local fillF=N("Frame",{
        Size=UDim2.new(ratio,0,1,0),
        BackgroundColor3=C.Accent, BorderSizePixel=0,
    },trackBG)
    Corner(3,fillF)

    local thumb=N("Frame",{
        Size=UDim2.new(0,11,0,11),
        Position=UDim2.new(ratio,-5.5,0.5,-5.5),
        BackgroundColor3=C.Text, BorderSizePixel=0, ZIndex=2,
    },trackBG)
    Corner(6,thumb)

    local sliding=false
    local function UpdateSlider(x)
        local rel=math.clamp((x-trackBG.AbsolutePosition.X)/math.max(1,trackBG.AbsoluteSize.X),0,1)
        local raw=mn+(mx-mn)*rel
        local snapped=math.clamp(math.floor(raw/inc+0.5)*inc,mn,mx)
        val=snapped
        local t2=(val-mn)/(mx-mn)
        fillF.Size=UDim2.new(t2,0,1,0)
        thumb.Position=UDim2.new(t2,-5.5,0.5,-5.5)
        valLbl.Text=tostring(math.floor(val*100+0.5)/100)
        cb(val)
    end

    trackBG.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true; UpdateSlider(i.Position.X) end
    end)
    UserInputService.InputChanged:Connect(function(i)
        if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then UpdateSlider(i.Position.X) end
    end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end
    end)

    card.MouseEnter:Connect(function() Tw(card,{BackgroundColor3=C.CardHov}) end)
    card.MouseLeave:Connect(function() Tw(card,{BackgroundColor3=C.Card}) end)

    card.Position=UDim2.new(0,10,0,curY)
    card.Parent=Content
    curY=curY+59
    Content.CanvasSize=UDim2.new(0,0,0,curY+20)
end

