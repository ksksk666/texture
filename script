    for i,opt in ipairs(opts) do
        local btn=mk("TextButton",{
            Text="  "..opt, Size=UDim2.new(1,0,0,26),
            BackgroundColor3=Color3.fromRGB(20,20,20), TextColor3=C.TextS,
            Font=Enum.Font.Gotham, TextSize=11, BorderSizePixel=0,
            AutoButtonColor=false, ZIndex=9002,
            TextXAlignment=Enum.TextXAlignment.Left, LayoutOrder=i,
        }, DropScroll)
        mk("UICorner",{CornerRadius=UDim.new(0,5)},btn)
        btn.MouseEnter:Connect(function() tw(btn,{BackgroundColor3=Color3.fromRGB(34,34,34),TextColor3=C.Text}) end)
        btn.MouseLeave:Connect(function() tw(btn,{BackgroundColor3=Color3.fromRGB(20,20,20),TextColor3=C.TextS}) end)
        btn.MouseButton1Click:Connect(function()
            if AD.selLbl then AD.selLbl.Text=opt end
            local saved=AD.cb; closeDrop(); if saved then saved(opt) end
        end)
    end
    local count=math.min(#opts,8); local menuH=count*27+10
    local menuW=math.max(190,trigger.AbsoluteSize.X)
    DropMenu.Size=UDim2.new(0,menuW,0,menuH)
    local px=trigger.AbsolutePosition.X
    local py=trigger.AbsolutePosition.Y+trigger.AbsoluteSize.Y+4
    local sw=ScreenGui.AbsoluteSize.X; local sh=ScreenGui.AbsoluteSize.Y
    if px+menuW>sw-8 then px=sw-menuW-8 end
    if py+menuH>sh-8 then py=trigger.AbsolutePosition.Y-menuH-4 end
    DropMenu.Position=UDim2.new(0,px,0,py); DropMenu.Visible=true
end

