    track.Position = UDim2.new(1,-52,0.5,-10)
    track.BackgroundColor3 = state and THEME.Accent or Color3.fromRGB(30,30,30)
    track.BorderSizePixel = 0; track.Parent = f
    Instance.new("UICorner",track).CornerRadius = UDim.new(0,10)

    local knob = Instance.new("Frame")
    knob.Size = UDim2.new(0,14,0,14)
    knob.Position = state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)
    knob.BackgroundColor3 = state and Color3.fromRGB(0,0,0) or THEME.SecondaryText
    knob.BorderSizePixel = 0; knob.Parent = track
    Instance.new("UICorner",knob).CornerRadius = UDim.new(0,7)

    local function update(v)
        state = v
        TweenService:Create(track, TweenInfo.new(0.15), {BackgroundColor3 = v and THEME.Accent or Color3.fromRGB(30,30,30)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.15), {
            Position = v and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
            BackgroundColor3 = v and Color3.fromRGB(0,0,0) or THEME.SecondaryText,
        }):Play()
        pcall(callback, v)
    end

    local hit = Instance.new("TextButton")
    hit.Size = UDim2.new(1,0,1,0); hit.BackgroundTransparency = 1
    hit.Text = ""; hit.ZIndex = 5; hit.Parent = f
    hit.MouseButton1Click:Connect(function() update(not state) end)
    f.MouseEnter:Connect(function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(18,18,18)}):Play() end)
    f.MouseLeave:Connect(function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(12,12,12)}):Play() end)

    return {Set=function(v) update(v) end, Get=function() return state end}
end

-- Slider
local function Slider(frame, text, minV, maxV, default, inc, callback)
    local val = default or minV
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1,0,0,56)
    f.BackgroundColor3 = Color3.fromRGB(12,12,12)
    f.BorderSizePixel = 0
    f.LayoutOrder = lo(frame)
    f.Parent = frame
    Instance.new("UICorner",f).CornerRadius = UDim.new(0,7)
    local fs = Instance.new("UIStroke"); fs.Color=THEME.Border; fs.Thickness=1; fs.Parent=f

    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0.75,0,0,16); lbl.Position = UDim2.new(0,12,0,8)
    lbl.BackgroundTransparency = 1; lbl.Text = text
    lbl.TextColor3 = THEME.SecondaryText; lbl.Font = THEME.MainFont; lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.Parent = f

    local valBadge = Instance.new("Frame")
    valBadge.Size = UDim2.new(0,48,0,16); valBadge.Position = UDim2.new(1,-60,0,8)
    valBadge.BackgroundColor3 = Color3.fromRGB(18,18,18); valBadge.BorderSizePixel = 0; valBadge.Parent = f
    Instance.new("UICorner",valBadge).CornerRadius = UDim.new(0,4)
    local valLbl = Instance.new("TextLabel")
    valLbl.Size = UDim2.new(1,0,1,0); valLbl.BackgroundTransparency = 1
    valLbl.Text = tostring(val); valLbl.TextColor3 = THEME.Accent
    valLbl.Font = THEME.BoldFont; valLbl.TextSize = 10; valLbl.Parent = valBadge

    local trackBG = Instance.new("Frame")
    trackBG.Size = UDim2.new(1,-24,0,5); trackBG.Position = UDim2.new(0,12,0,36)
    trackBG.BackgroundColor3 = Color3.fromRGB(22,22,22); trackBG.BorderSizePixel = 0; trackBG.Parent = f
    Instance.new("UICorner",trackBG).CornerRadius = UDim.new(0,3)

    local ratio = (val-minV)/(maxV-minV)
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new(ratio,0,1,0); fill.BackgroundColor3 = THEME.Accent
    fill.BorderSizePixel = 0; fill.Parent = trackBG
    Instance.new("UICorner",fill).CornerRadius = UDim.new(0,3)

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0,11,0,11); thumb.Position = UDim2.new(ratio,-5.5,0.5,-5.5)
    thumb.BackgroundColor3 = THEME.Text; thumb.BorderSizePixel = 0; thumb.ZIndex = 2; thumb.Parent = trackBG
    Instance.new("UICorner",thumb).CornerRadius = UDim.new(0,6)

    local sliding = false
    local function upd(x)
        local rel = math.clamp((x - trackBG.AbsolutePosition.X) / trackBG.AbsoluteSize.X, 0, 1)
        local snapped = math.clamp(math.floor((minV+(maxV-minV)*rel)/inc+0.5)*inc, minV, maxV)
        val = snapped; local t = (val-minV)/(maxV-minV)
        fill.Size = UDim2.new(t,0,1,0); thumb.Position = UDim2.new(t,-5.5,0.5,-5.5)
        valLbl.Text = tostring(math.floor(val*100+0.5)/100); pcall(callback, val)
    end
    trackBG.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true; upd(i.Position.X) end end)
    UserInputService.InputChanged:Connect(function(i) if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end end)

    f.MouseEnter:Connect(function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(18,18,18)}):Play() end)
    f.MouseLeave:Connect(function() TweenService:Create(f,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(12,12,12)}):Play() end)
end

