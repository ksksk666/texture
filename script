local function InfoCard(p,title,content,accent)
    local ac=accent or C.AccentD
    local card=mk("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundColor3=C.Card,BorderSizePixel=0,LayoutOrder=nextLO(p)},p)
    mk("UICorner",{CornerRadius=UDim.new(0,8)},card); mk("UIStroke",{Color=C.Border,Thickness=1},card)
    mk("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10),PaddingLeft=UDim.new(0,14),PaddingRight=UDim.new(0,12)},card)
    mk("UIListLayout",{FillDirection=Enum.FillDirection.Vertical,Padding=UDim.new(0,4),SortOrder=Enum.SortOrder.LayoutOrder},card)
    mk("TextLabel",{Text=title,Size=UDim2.new(1,0,0,14),LayoutOrder=1,BackgroundTransparency=1,TextColor3=ac,Font=Enum.Font.GothamBold,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left},card)
    return mk("TextLabel",{Text=content,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,LayoutOrder=2,BackgroundTransparency=1,TextColor3=C.TextS,Font=Enum.Font.Gotham,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true},card)
end

local FPS_Labels,Ping_Labels={},{}
local function LiveStats(p)
    local row=mk("Frame",{Size=UDim2.new(1,0,0,54),BackgroundTransparency=1,LayoutOrder=nextLO(p)},p)
    mk("UIListLayout",{FillDirection=Enum.FillDirection.Horizontal,Padding=UDim.new(0,6),SortOrder=Enum.SortOrder.LayoutOrder},row)
    local function mkSC(lbl,col,ord)
        local c=mk("Frame",{Size=UDim2.new(0.5,-3,1,0),BackgroundColor3=C.Card,BorderSizePixel=0,LayoutOrder=ord},row)
        mk("UICorner",{CornerRadius=UDim.new(0,8)},c); mk("UIStroke",{Color=C.Border,Thickness=1},c)
        mk("UIPadding",{PaddingTop=UDim.new(0,8),PaddingBottom=UDim.new(0,8),PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12)},c)
        mk("UIListLayout",{FillDirection=Enum.FillDirection.Vertical,Padding=UDim.new(0,2),SortOrder=Enum.SortOrder.LayoutOrder},c)
        local vl=mk("TextLabel",{Text="—",Size=UDim2.new(1,0,0,20),LayoutOrder=1,BackgroundTransparency=1,TextColor3=col,Font=Enum.Font.GothamBold,TextSize=16,TextXAlignment=Enum.TextXAlignment.Left},c)
        mk("TextLabel",{Text=lbl,Size=UDim2.new(1,0,0,11),LayoutOrder=2,BackgroundTransparency=1,TextColor3=C.TextM,Font=Enum.Font.Gotham,TextSize=9,TextXAlignment=Enum.TextXAlignment.Left},c)
        return vl
    end
    table.insert(FPS_Labels,  mkSC("FPS", C.Green,1))
    table.insert(Ping_Labels, mkSC("PING",C.Blue, 2))
end

local function ColorPick(p,label,cb)
    local colors={
        White=Color3.fromRGB(255,255,255), Silver=Color3.fromRGB(180,180,180),
        Red=Color3.fromRGB(255,60,60),     Crimson=Color3.fromRGB(220,20,60),
        Orange=Color3.fromRGB(255,140,0),  Gold=Color3.fromRGB(220,168,32),
        Yellow=Color3.fromRGB(255,230,0),  Lime=Color3.fromRGB(100,255,0),
        Green=Color3.fromRGB(50,225,90),   Teal=Color3.fromRGB(0,200,185),
        Cyan=Color3.fromRGB(0,220,220),    Sky=Color3.fromRGB(50,180,255),
        Blue=Color3.fromRGB(50,130,255),   Navy=Color3.fromRGB(0,0,180),
        Purple=Color3.fromRGB(150,60,255), Violet=Color3.fromRGB(200,80,255),
        Pink=Color3.fromRGB(255,80,200),   Magenta=Color3.fromRGB(255,0,180),
