        local f2=hd:FindFirstChild("face"); if f2 then f2.Transparency=v and 1 or 0 end
    end)
    Toggle(p,"Invisible",false,function(v)
        S.Invis=v
        local c=LP.Character; if not c then return end
        for _,part in ipairs(c:GetDescendants()) do
            if part:IsA("BasePart") or part:IsA("Decal") then part.Transparency=v and 1 or 0 end
        end
    end)
    Toggle(p,"Slippery Mode",false,function(v) S.Slippery=v end)
    Toggle(p,"Low Gravity",  false,function(v) workspace.Gravity=v and 40 or 196.2 end)
    Toggle(p,"High Jump",    false,function(v)
        local h=LP.Character and LP.Character:FindFirstChild("Humanoid")
        if h then h.JumpPower=v and 180 or 50 end
    end)
    Toggle(p,"Speed Boost",  false,function(v)
        local h=LP.Character and LP.Character:FindFirstChild("Humanoid")
        if h then h.WalkSpeed=v and 100 or 16 end
    end)
    Section(p,"Cosmetics")
    Toggle(p,"Character Trail",false,function(v)
        S.TrailOn=v
        local c=LP.Character; if not c then return end
        local root=c:FindFirstChild("HumanoidRootPart"); local head=c:FindFirstChild("Head")
        if root and head then
            if v then
                local a0=Instance.new("Attachment",root); a0.Name="TrA0"
                local a1=Instance.new("Attachment",head);  a1.Name="TrA1"
                local tr=Instance.new("Trail")
                tr.Attachment0=a0; tr.Attachment1=a1; tr.Lifetime=0.9
                tr.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(S.TrailR,S.TrailG,S.TrailB)),ColorSequenceKeypoint.new(1,Color3.fromRGB(50,0,140))})
                tr.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)})
                tr.WidthScale=NumberSequence.new(1,0); tr.Parent=c; tr.Name="WSTrail"
            else
                for _,n in ipairs({"WSTrail","TrA0","TrA1"}) do
                    local f2=c:FindFirstChild(n) or (root and root:FindFirstChild(n)) or (head and head:FindFirstChild(n))
                    if f2 then f2:Destroy() end
                end
            end
        end
    end)
    Toggle(p,"Body Aura",false,function(v)
        S.AuraOn=v
        local c=LP.Character; if not c then return end
        local root=c:FindFirstChild("HumanoidRootPart"); if not root then return end
        if v then
            local part=Instance.new("Part"); part.Size=Vector3.new(4,5,4)
            part.Anchored=false; part.CanCollide=false; part.Transparency=1; part.Name="WSAura"; part.Parent=c
            local w=Instance.new("WeldConstraint"); w.Part0=root; w.Part1=part; w.Parent=part
            local em=Instance.new("ParticleEmitter")
            em.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(210,210,210)),ColorSequenceKeypoint.new(1,Color3.fromRGB(80,80,80))})
            em.LightEmission=0.4; em.Rate=28; em.Lifetime=NumberRange.new(0.5,1.2)
            em.Speed=NumberRange.new(2,5); em.SpreadAngle=Vector2.new(180,180); em.Parent=part
        else
            local f2=c:FindFirstChild("WSAura"); if f2 then f2:Destroy() end
        end
    end)
    Toggle(p,"Ground Smoke",false,function(v) S.GroundSmoke=v end)
    Section(p,"Trail Color")
    Slider(p,"Red",   0,255,200,1,function(v) S.TrailR=v end)
    Slider(p,"Green", 0,255, 80,1,function(v) S.TrailG=v end)
    Slider(p,"Blue",  0,255,255,1,function(v) S.TrailB=v end)
    Button(p,"Reset Character",function()
        local h=LP.Character and LP.Character:FindFirstChild("Humanoid"); if h then h.Health=0 end
    end,C.Red)
end

