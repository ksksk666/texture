        local c=LocalPlayer.Character; if not c then return end
        local hd=c:FindFirstChild("Head"); if not hd then return end
        hd.Transparency=v and 1 or 0
        local f=hd:FindFirstChild("face"); if f then f.Transparency=v and 1 or 0 end
    end)
    Toggle("Invisible", false, function(v)
        InvisEnabled=v
        local c=LocalPlayer.Character; if not c then return end
        for _, p in ipairs(c:GetDescendants()) do
            if p:IsA("BasePart") or p:IsA("Decal") then p.Transparency=v and 1 or 0 end
        end
    end)
    Toggle("Slippery Mode", false, function(v) SlipperyEnabled=v end)
    Section("Cosmetics")
    Toggle("Character Trail", false, function(v)
        TrailEnabled=v
        local c=LocalPlayer.Character; if not c then return end
        local root=c:FindFirstChild("HumanoidRootPart"); local head=c:FindFirstChild("Head")
        if root and head then
            if v then
                local a0=Instance.new("Attachment",root); a0.Name="TrAtt0"
                local a1=Instance.new("Attachment",head);  a1.Name="TrAtt1"
                local tr=Instance.new("Trail")
                tr.Attachment0=a0; tr.Attachment1=a1; tr.Lifetime=0.9
                tr.Color=ColorSequence.new({
                    ColorSequenceKeypoint.new(0,  Color3.fromRGB(_G.TrailR or 200,_G.TrailG or 80,_G.TrailB or 255)),
                    ColorSequenceKeypoint.new(0.5,Color3.fromRGB(100,40,220)),
                    ColorSequenceKeypoint.new(1,  Color3.fromRGB(50,0,140)),
                })
                tr.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0),NumberSequenceKeypoint.new(1,1)})
                tr.WidthScale=NumberSequence.new(1,0); tr.Parent=c; tr.Name="WSTrail"
            else
                for _, n in ipairs({"WSTrail","TrAtt0","TrAtt1"}) do
                    local f=c:FindFirstChild(n) or root:FindFirstChild(n) or head:FindFirstChild(n)
                    if f then f:Destroy() end
                end
            end
        end
    end)
    Toggle("Body Aura", false, function(v)
        AuraEnabled=v
        local c=LocalPlayer.Character; if not c then return end
        local root=c:FindFirstChild("HumanoidRootPart"); if not root then return end
        if v then
            local part=Instance.new("Part"); part.Size=Vector3.new(4,5,4)
            part.Anchored=false; part.CanCollide=false; part.Transparency=1
            part.Name="WSAura"; part.Parent=c
            local w=Instance.new("WeldConstraint"); w.Part0=root; w.Part1=part; w.Parent=part
            local em=Instance.new("ParticleEmitter")
            em.Color=ColorSequence.new({ColorSequenceKeypoint.new(0,Color3.fromRGB(200,200,200)),ColorSequenceKeypoint.new(1,Color3.fromRGB(100,100,100))})
            em.LightEmission=0.5; em.Rate=30; em.Lifetime=NumberRange.new(0.5,1.2)
            em.Speed=NumberRange.new(2,5); em.SpreadAngle=Vector2.new(180,180); em.Parent=part
        else
            local f=c:FindFirstChild("WSAura"); if f then f:Destroy() end
        end
    end)
    Toggle("Ground Smoke Trail", false, function(v) GroundTrailEnabled=v end)
    Section("Trail Color")
    Slider("Red",   0,255,200,1, function(v) _G.TrailR=v end)
    Slider("Green", 0,255, 80,1, function(v) _G.TrailG=v end)
    Slider("Blue",  0,255,255,1, function(v) _G.TrailB=v end)
    Button("Reset Character", function()
        local h=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")
        if h then h.Health=0 end
    end, T.Red)
