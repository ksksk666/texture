-- Heartbeat
RunService.Heartbeat:Connect(function(dt)
    if GodModeEnabled and LocalPlayer.Character then
        local hum=LocalPlayer.Character:FindFirstChild("Humanoid")
        if hum then hum.Health=hum.MaxHealth end
    end
    if SlipperyEnabled and LocalPlayer.Character then
        for _, p in ipairs(LocalPlayer.Character:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CustomPhysicalProperties=PhysicalProperties.new(0.1,0,0,0,0)
            end
        end
    end
    if DayCycleEnabled   then Lighting.ClockTime=(Lighting.ClockTime+(_G.DayCycleSpeed or 0.1)*dt)%24 end
    if SkyboxSpinEnabled then
        if _G.SkyboxSpinAxis=="Latitude" then
            Lighting.GeographicLatitude=(Lighting.GeographicLatitude+SkyboxSpinSpeed*dt*10)%180-90
        else
            Lighting.ClockTime=(Lighting.ClockTime+SkyboxSpinSpeed*dt*0.5)%24
        end
    end
    if RainbowLighting then
        local hue=(tick()*(_G.RainbowSpeed or 0.08))%1
        Lighting.Ambient=Color3.fromHSV(hue,0.55,0.85)
        Lighting.OutdoorAmbient=Color3.fromHSV((hue+0.5)%1,0.55,0.85)
    end
    if FlickerLights then
        local i=_G.FlickerIntensity or 2
        Lighting.Brightness=math.random(math.max(1,math.floor((2-i*0.5)*10)),math.floor((2+i*0.5)*10))/10
    end
end)

-- Ground smoke trail
local lastGP=nil
RunService.Heartbeat:Connect(function()
    if GroundTrailEnabled and LocalPlayer.Character then
        local root=LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            if lastGP and (root.Position-lastGP).Magnitude>1 then
                for _ = 1, math.floor(_G.SmokeDensity or 3) do
                    local s=Instance.new("Part")
                    s.Size=Vector3.new(0.8,0.8,0.8); s.Anchored=true; s.CanCollide=false
                    s.Transparency=0.5; s.Material=Enum.Material.SmoothPlastic
                    s.Color=Color3.fromRGB(160,160,160)
                    s.CFrame=CFrame.new(root.Position-Vector3.new(math.random(-1,1),2.5,math.random(-1,1)))
                    s.Parent=workspace
                    local em=Instance.new("ParticleEmitter",s)
                    em.Rate=15; em.Lifetime=NumberRange.new(0.3,0.8)
                    em.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.6),NumberSequenceKeypoint.new(1,2.5)})
                    em.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.2),NumberSequenceKeypoint.new(1,1)})
                    em.Color=ColorSequence.new(Color3.fromRGB(180,180,180))
                    em.Speed=NumberRange.new(0.5,2); Debris:AddItem(s,1.2)
                end
            end
            lastGP=root.Position
        end
    end
end)

-- Stepped: noclip, fly, weather
RunService.Stepped:Connect(function()
    if Noclip and LocalPlayer.Character then
        for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide=false end
        end
    end

    if FlyEnabled and LocalPlayer.Character then
        local hum  = LocalPlayer.Character:FindFirstChild("Humanoid")
        local root = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hum and root then
            local cf=Camera.CFrame; local dir=Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir=dir+cf.LookVector    end
            if UserInputService:IsKeyDown(Enum.KeyCode.S)         then dir=dir-cf.LookVector    end
            if UserInputService:IsKeyDown(Enum.KeyCode.A)         then dir=dir-cf.RightVector   end
            if UserInputService:IsKeyDown(Enum.KeyCode.D)         then dir=dir+cf.RightVector   end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
            if dir.Magnitude>0 then dir=dir.Unit end
            root.Velocity=dir*FlySpeed; hum.PlatformStand=dir.Magnitude>0
        end
    else
        if LocalPlayer.Character then
            local hum=LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum.PlatformStand=false end
        end
    end

    local density=math.floor(_G.WeatherDensity or 5)
    local windX=math.cos(math.rad(_G.WindDirection or 0))*(_G.WindStrength or 10)
    local windZ=math.sin(math.rad(_G.WindDirection or 0))*(_G.WindStrength or 10)
    local camPos=Camera.CFrame.Position

    local function SpawnDrop(color,sx,sy,mat,vy,life,wm)
        local d=Instance.new("Part")
        d.Size=Vector3.new(sx,sy,sx); d.Material=mat; d.Color=color
        d.CanCollide=false; d.Anchored=false; d.CastShadow=false
        d.Position=camPos+Vector3.new(math.random(-70,70),55,math.random(-70,70))
        d.Parent=EffectsFolder
        local vel=Instance.new("BodyVelocity")
        vel.Velocity=Vector3.new(windX*(wm or 1)+math.random(-3,3),vy,windZ*(wm or 1)+math.random(-3,3))
        vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=d; Debris:AddItem(d,life)
    end

    if WeatherType=="Rainy" then
        for _ = 1,density do SpawnDrop(Color3.fromRGB(170,200,255),0.05,1.5,Enum.Material.Glass,-120,1.2,0.5) end
    elseif WeatherType=="Stormy" or WeatherType=="Hurricane" then
        for _ = 1,density+4 do SpawnDrop(Color3.fromRGB(140,175,220),0.06,1.8,Enum.Material.Glass,-155,1.0,2.0) end
    elseif WeatherType=="Snowy" or WeatherType=="Cold" then
        for _ = 1,math.max(2,density-1) do
            local f=Instance.new("Part"); f.Size=Vector3.new(0.3,0.1,0.3)
            f.Material=Enum.Material.SmoothPlastic; f.Color=Color3.fromRGB(235,245,255)
            f.CanCollide=false; f.Anchored=false; f.Shape=Enum.PartType.Ball
            f.Position=camPos+Vector3.new(math.random(-70,70),45,math.random(-70,70)); f.Parent=EffectsFolder
            local vel=Instance.new("BodyVelocity")
            vel.Velocity=Vector3.new(windX*0.3+math.random(-5,5),-18,windZ*0.3+math.random(-5,5))
            vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=f; Debris:AddItem(f,3)
        end
    elseif WeatherType=="Blizzard" then
        for _ = 1,density+5 do SpawnDrop(Color3.fromRGB(220,235,255),0.3,0.3,Enum.Material.SmoothPlastic,-25,2.5,3.0) end
    elseif WeatherType=="Tornado" then
        for _ = 1,density+2 do
            local db=Instance.new("Part")
            db.Size=Vector3.new(math.random(1,3)*0.4,math.random(1,3)*0.4,math.random(1,3)*0.4)
            db.Material=Enum.Material.SmoothPlastic
            db.Color=Color3.fromRGB(100+math.random(0,40),100+math.random(0,40),80+math.random(0,30))
            db.CanCollide=false; db.Anchored=false
            local angle=tick()*3; local radius=math.random(10,30)
            db.Position=camPos+Vector3.new(math.cos(angle)*radius+math.random(-5,5),math.random(-10,20),math.sin(angle)*radius+math.random(-5,5))
            db.Parent=EffectsFolder
            local vel=Instance.new("BodyVelocity")
            vel.Velocity=Vector3.new(math.cos(angle+1.5)*40,math.random(5,20),math.sin(angle+1.5)*40)
            vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=db; Debris:AddItem(db,1.5)
        end
    end
end)

-- Meteor loop
RunService.Stepped:Connect(function(_,dt)
    if not MeteorEnabled then return end
    MeteorTimer+=dt
    if MeteorTimer < 1/math.max(0.01,MeteorRate) then return end
    MeteorTimer=0
    local spawnPos=Camera.CFrame.Position+Vector3.new(math.random(-160,160),math.random(90,160),math.random(-160,160))
    local target  =Camera.CFrame.Position+Vector3.new(math.random(-40,40),-60,math.random(-40,40))
    local dir=(target-spawnPos).Unit
    local meteor=Instance.new("Part")
    meteor.Size=Vector3.new(MeteorSize,MeteorSize*2.8,MeteorSize); meteor.Material=Enum.Material.Rock
    meteor.Color=_G.MeteorColor or Color3.fromRGB(110,90,70); meteor.CanCollide=false
    meteor.CFrame=CFrame.new(spawnPos,spawnPos+dir); meteor.Parent=workspace
    local fire=Instance.new("Fire",meteor)
    fire.Color=_G.MeteorFireColor or Color3.fromRGB(255,140,40); fire.SecondaryColor=Color3.fromRGB(255,220,80)
    fire.Size=MeteorSize*3.5; fire.Heat=22
    local light=Instance.new("PointLight",meteor); light.Brightness=6; light.Range=MeteorSize*12; light.Color=fire.Color
    local vel=Instance.new("BodyVelocity"); vel.Velocity=dir*MeteorSpeed; vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=meteor
    local impactDelay=(spawnPos-target).Magnitude/math.max(1,MeteorSpeed)+0.5
    task.delay(impactDelay,function()
        if meteor and meteor.Parent then
            if _G.MeteorExplosions then
                local boom=Instance.new("Explosion"); boom.BlastRadius=_G.MeteorExplosionRadius or 5
                boom.BlastPressure=0; boom.Position=meteor.Position; boom.Parent=workspace
                local ob=Lighting.Brightness; Lighting.Brightness=ob+2
                task.delay(0.1,function() Lighting.Brightness=ob end)
            end
            meteor:Destroy()
        end
    end)
    Debris:AddItem(meteor,impactDelay+1)
end)

-- Thunder loop
RunService.Stepped:Connect(function(_,dt)
    if not ThunderEnabled then ThunderTimer=0; return end
    ThunderTimer+=dt
    local interval=_G.ThunderInterval or 5
    if ThunderTimer < interval*(0.75+math.random()*0.5) then return end
    ThunderTimer=0
    local ob=Lighting.Brightness
    Lighting.Brightness=ob+5
    task.delay(0.06,  function() Lighting.Brightness=ob     end)
    task.delay(0.16,  function() Lighting.Brightness=ob+4.5 end)
    task.delay(0.24,  function() Lighting.Brightness=ob     end)
    task.delay(math.random(5,20)*0.1,function()
        local s=Instance.new("Sound",workspace)
        s.SoundId="rbxassetid://130758378"; s.Volume=0.6+math.random()*0.4; s.PlaybackSpeed=0.8+math.random()*0.4
        s:Play(); Debris:AddItem(s,5)
    end)
end)

-- ESP loop
RunService.RenderStepped:Connect(function()
    for _, v in ipairs(Players:GetPlayers()) do
        if v~=LocalPlayer and v.Character then
            local char=v.Character
            local hrp =char:FindFirstChild("HumanoidRootPart")
            local head=char:FindFirstChild("Head")
            local hum =char:FindFirstChild("Humanoid")
            if hrp and head then
                local bb=char:FindFirstChild("WSESP")
                local needBB = ESP_Names or ESP_Distance or ESP_Health
                if needBB then
                    if not bb then
                        bb=Instance.new("BillboardGui"); bb.Name="WSESP"; bb.AlwaysOnTop=true
                        bb.Size=UDim2.new(0,134,0,74); bb.StudsOffset=Vector3.new(0,3.8,0)
                        bb.Adornee=head; bb.Parent=char
                    end
                    local nl=bb:FindFirstChild("NL")
                    if ESP_Names then
                        if not nl then
                            nl=Instance.new("TextLabel",bb); nl.Name="NL"
                            nl.Size=UDim2.new(1,0,0,22); nl.Position=UDim2.new(0,0,0,0)
                            nl.BackgroundTransparency=1; nl.TextColor3=Color3.fromRGB(255,255,255)
                            nl.TextStrokeTransparency=0; nl.Font=Enum.Font.GothamBold; nl.TextScaled=true
                        end
                        nl.Text=v.Name; nl.Visible=true
                    elseif nl then nl.Visible=false end
                    local dl=bb:FindFirstChild("DL")
                    if ESP_Distance then
                        if not dl then
                            dl=Instance.new("TextLabel",bb); dl.Name="DL"
                            dl.Size=UDim2.new(1,0,0,18); dl.Position=UDim2.new(0,0,0,22)
                            dl.BackgroundTransparency=1; dl.TextColor3=Color3.fromRGB(220,220,220)
                            dl.TextStrokeTransparency=0; dl.Font=Enum.Font.Gotham; dl.TextScaled=true
                        end
                        local myHRP=LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                        if myHRP then dl.Text=math.floor((hrp.Position-myHRP.Position).Magnitude).." studs" end
                        dl.Visible=true
                    elseif dl then dl.Visible=false end
                    local hl=bb:FindFirstChild("HL")
                    if ESP_Health and hum then
                        if not hl then
                            hl=Instance.new("TextLabel",bb); hl.Name="HL"
                            hl.Size=UDim2.new(1,0,0,18); hl.Position=UDim2.new(0,0,0,44)
                            hl.BackgroundTransparency=1; hl.TextStrokeTransparency=0
                            hl.Font=Enum.Font.Gotham; hl.TextScaled=true
                        end
                        local pct=hum.Health/math.max(1,hum.MaxHealth)
                        hl.TextColor3=Color3.fromRGB(math.floor((1-pct)*255),math.floor(pct*255),50)
                        hl.Text="HP "..math.floor(hum.Health).."/"..math.floor(hum.MaxHealth); hl.Visible=true
                    elseif hl then hl.Visible=false end
                else
                    if bb then bb:Destroy() end
                end

                local exHL=char:FindFirstChild("WSHighlight")
                if ESP_HighlightEnabled then
                    local hlColor=ESP_HighlightColor
                    if _G.ESPTeamColor then
                        pcall(function() hlColor=v.TeamColor and Color3.fromBrickColor(v.TeamColor) or hlColor end)
                    end
                    if not exHL then
                        local h2=Instance.new("Highlight",char); h2.Name="WSHighlight"
                        h2.FillColor=hlColor; h2.OutlineColor=Color3.fromRGB(255,255,255)
                        h2.FillTransparency=ESP_HighlightFill; h2.OutlineTransparency=ESP_HighlightOutline
                        h2.DepthMode=_G.ChamsOnTop and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
                    else
                        exHL.FillColor=hlColor; exHL.FillTransparency=ESP_HighlightFill
                        exHL.OutlineTransparency=ESP_HighlightOutline
                        exHL.DepthMode=_G.ChamsOnTop and Enum.HighlightDepthMode.AlwaysOnTop or Enum.HighlightDepthMode.Occluded
                    end
                else
                    if exHL then exHL:Destroy() end
                end
            end
        end
    end
end)

