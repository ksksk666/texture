local function Toggle(p,label,default,cb)
    local state=default or false; local lo=nextLO(p)
    local card=mk("Frame",{Size=UDim2.new(1,0,0,40),BackgroundColor3=C.Card,BorderSizePixel=0,LayoutOrder=lo},p)
    mk("UICorner",{CornerRadius=UDim.new(0,8)},card)
    mk("UIStroke",{Color=C.Border,Thickness=1},card)
    mk("UIPadding",{PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12)},card)
    mk("TextLabel",{Text=label,Size=UDim2.new(1,-60,1,0),BackgroundTransparency=1,TextColor3=C.Text,
        Font=Enum.Font.Gotham,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left},card)
    local track=mk("Frame",{Size=UDim2.new(0,40,0,20),Position=UDim2.new(1,-44,0.5,-10),
        BackgroundColor3=state and C.Accent or C.TogOff,BorderSizePixel=0},card)
    mk("UICorner",{CornerRadius=UDim.new(0,10)},track)
    local knob=mk("Frame",{
        Size=UDim2.new(0,14,0,14),
        Position=state and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
        BackgroundColor3=state and C.BG or C.TextS, BorderSizePixel=0,
    },track)
    mk("UICorner",{CornerRadius=UDim.new(0,7)},knob)
    local function update(v)
        state=v
        tw(track,{BackgroundColor3=v and C.Accent or C.TogOff})
        tw(knob,{Position=v and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
                 BackgroundColor3=v and C.BG or C.TextS})
        pcall(cb,v)
    end
    local hit=mk("TextButton",{Text="",Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,ZIndex=5},card)
    hit.MouseButton1Click:Connect(function() update(not state) end)
    card.MouseEnter:Connect(function() tw(card,{BackgroundColor3=C.CardH}) end)
    card.MouseLeave:Connect(function() tw(card,{BackgroundColor3=C.Card}) end)
    return {Set=function(v) update(v) end,Get=function() return state end}
end

local function Slider(p,label,mn,mx,default,inc,cb)
    local val=default or mn; local lo=nextLO(p)
    local card=mk("Frame",{Size=UDim2.new(1,0,0,56),BackgroundColor3=C.Card,BorderSizePixel=0,LayoutOrder=lo},p)
    mk("UICorner",{CornerRadius=UDim.new(0,8)},card)
    mk("UIStroke",{Color=C.Border,Thickness=1},card)
    mk("UIPadding",{PaddingTop=UDim.new(0,8),PaddingBottom=UDim.new(0,8),
        PaddingLeft=UDim.new(0,12),PaddingRight=UDim.new(0,12)},card)
    mk("UIListLayout",{FillDirection=Enum.FillDirection.Vertical,Padding=UDim.new(0,6),SortOrder=Enum.SortOrder.LayoutOrder},card)
    local topRow=mk("Frame",{Size=UDim2.new(1,0,0,13),BackgroundTransparency=1,LayoutOrder=1},card)
    mk("TextLabel",{Text=label,Size=UDim2.new(0.75,0,1,0),BackgroundTransparency=1,TextColor3=C.TextS,
        Font=Enum.Font.Gotham,TextSize=11,TextXAlignment=Enum.TextXAlignment.Left},topRow)
    local badge=mk("Frame",{Size=UDim2.new(0,52,0,14),Position=UDim2.new(1,-52,0,0),
        BackgroundColor3=Color3.fromRGB(14,14,14),BorderSizePixel=0},topRow)
    mk("UICorner",{CornerRadius=UDim.new(0,4)},badge)
    local valLbl=mk("TextLabel",{Text=tostring(val),Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        TextColor3=C.Text,Font=Enum.Font.GothamBold,TextSize=10,TextXAlignment=Enum.TextXAlignment.Center},badge)
    local trackBG=mk("Frame",{Size=UDim2.new(1,0,0,5),BackgroundColor3=C.SlBG,BorderSizePixel=0,LayoutOrder=2},card)
    mk("UICorner",{CornerRadius=UDim.new(0,3)},trackBG)
    local ratio=(val-mn)/(mx-mn)
    local fill=mk("Frame",{Size=UDim2.new(ratio,0,1,0),BackgroundColor3=C.Accent,BorderSizePixel=0},trackBG)
    mk("UICorner",{CornerRadius=UDim.new(0,3)},fill)
    local thumb=mk("Frame",{Size=UDim2.new(0,11,0,11),Position=UDim2.new(ratio,-5.5,0.5,-5.5),
        BackgroundColor3=C.Text,BorderSizePixel=0,ZIndex=2},trackBG)
    mk("UICorner",{CornerRadius=UDim.new(0,6)},thumb)
    local sliding=false
    local function upd(x)
        local rel=math.clamp((x-trackBG.AbsolutePosition.X)/trackBG.AbsoluteSize.X,0,1)
        local snapped=math.clamp(math.floor((mn+(mx-mn)*rel)/inc+0.5)*inc,mn,mx)
        val=snapped; local t=(val-mn)/(mx-mn)
        fill.Size=UDim2.new(t,0,1,0); thumb.Position=UDim2.new(t,-5.5,0.5,-5.5)
        valLbl.Text=tostring(math.floor(val*100+0.5)/100); pcall(cb,val)
    end
    trackBG.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=true;upd(i.Position.X) end end)
    UIS.InputChanged:Connect(function(i) if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end end)
    UIS.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sliding=false end end)
    card.MouseEnter:Connect(function() tw(card,{BackgroundColor3=C.CardH}) end)
    card.MouseLeave:Connect(function() tw(card,{BackgroundColor3=C.Card}) end)
    return {SetValue=function(v)
        val=math.clamp(v,mn,mx); local t=(val-mn)/(mx-mn)
        fill.Size=UDim2.new(t,0,1,0); thumb.Position=UDim2.new(t,-5.5,0.5,-5.5)
        valLbl.Text=tostring(math.floor(val*100+0.5)/100)
    end}
end

local function Button(p,label,cb,color)
