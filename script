-- Particle state
local rainActive, rainType = false, "none"

local function setWeather(name)
    for _, o in ipairs(FXFolder:GetChildren()) do o:Destroy() end
    S.Weather = name; S.Thunder = false; rainActive = false; rainType = "none"
    local w = WeatherData[name]
    if not w then
        Lighting.ClockTime = OrigLight.ClockTime; Lighting.Brightness = OrigLight.Brightness
        Lighting.Ambient = OrigLight.Ambient; Lighting.OutdoorAmbient = OrigLight.OutdoorAmbient
        Lighting.FogEnd = OrigLight.FogEnd; Lighting.FogStart = OrigLight.FogStart
        Lighting.FogColor = OrigLight.FogColor
        return
    end
    Lighting.ClockTime = w.t or 12; Lighting.Brightness = w.b or 1
    Lighting.Ambient = w.a; Lighting.OutdoorAmbient = w.oa
    Lighting.FogEnd = w.fe; Lighting.FogStart = w.fs or 0; Lighting.FogColor = w.fc
    if w.thunder then S.Thunder = true end
    if w.rain  then rainActive=true; rainType="rain"  end
    if w.snow  then rainActive=true; rainType="snow"  end
    if w.sand  then rainActive=true; rainType="sand"  end
    if w.acid  then rainActive=true; rainType="acid"  end
end

