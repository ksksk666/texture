-- Heartbeat
local lastGroundPos = nil
RunService.Heartbeat:Connect(function(dt)
    -- God mode
    if S.GodMode and player.Character then
        local hum=player.Character:FindFirstChild("Humanoid"); if hum then hum.Health=hum.MaxHealth end
    end
    -- Slippery
    if S.Slippery and player.Character then
        for _,pt in ipairs(player.Character:GetDescendants()) do
            if pt:IsA("BasePart") then pt.CustomPhysicalProperties=PhysicalProperties.new(0.1,0,0,0,0) end
        end
    end
    -- Day cycle
    if S.DayCycle then Lighting.ClockTime=(Lighting.ClockTime+(S.DayCycleSpeed or 0.1)*dt)%24 end
    -- Skybox spin
    if S.SkyboxSpin then Lighting.ClockTime=(Lighting.ClockTime+(S.SpinSpeed or 1)*dt*0.5)%24 end
    -- Rainbow
    if S.Rainbow then
        local hue=(tick()*(S.RainbowSpeed or 0.08))%1
        Lighting.Ambient=Color3.fromHSV(hue,0.4,0.8)
        Lighting.OutdoorAmbient=Color3.fromHSV((hue+0.5)%1,0.4,0.8)
    end
    -- Flicker
    if S.Flicker then
        local i=S.FlickerInt or 2
        Lighting.Brightness=math.random(math.max(1,math.floor((2-i*0.5)*10)),math.floor((2+i*0.5)*10))/10
    end
    -- Ground smoke
    if S.GroundSmoke and player.Character then
        local root=player.Character:FindFirstChild("HumanoidRootPart")
        if root then
            if lastGroundPos and (root.Position-lastGroundPos).Magnitude>1.2 then
                for _=1,math.floor(S.SmokeDensity or 3) do
                    local sp=Instance.new("Part"); sp.Size=Vector3.new(0.7,0.7,0.7)
                    sp.Anchored=true; sp.CanCollide=false; sp.Transparency=0.5
                    sp.Material=Enum.Material.SmoothPlastic; sp.Color=Color3.fromRGB(155,155,155)
                    sp.CFrame=CFrame.new(root.Position+Vector3.new(math.random(-1,1),-2.3,math.random(-1,1)))
                    sp.Parent=workspace
                    local em=Instance.new("ParticleEmitter",sp); em.Rate=12; em.Lifetime=NumberRange.new(0.3,0.8)
                    em.Size=NumberSequence.new({NumberSequenceKeypoint.new(0,0.6),NumberSequenceKeypoint.new(1,2.2)})
                    em.Transparency=NumberSequence.new({NumberSequenceKeypoint.new(0,0.3),NumberSequenceKeypoint.new(1,1)})
                    em.Color=ColorSequence.new(Color3.fromRGB(165,165,165)); em.Speed=NumberRange.new(0.5,2)
                    Debris:AddItem(sp,1.0)
                end
            end
            lastGroundPos=root.Position
        end
    end
end)

-- Stepped
RunService.Stepped:Connect(function()
    -- Noclip
    if S.Noclip and player.Character then
        for _,pt in ipairs(player.Character:GetDescendants()) do
            if pt:IsA("BasePart") then pt.CanCollide=false end
        end
    end
    -- Fly
    if S.Fly and player.Character then
        local hum=player.Character:FindFirstChild("Humanoid")
        local root=player.Character:FindFirstChild("HumanoidRootPart")
        if hum and root then
            local cf=Camera.CFrame; local dir=Vector3.new()
            if UserInputService:IsKeyDown(Enum.KeyCode.W)         then dir=dir+cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S)         then dir=dir-cf.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A)         then dir=dir-cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D)         then dir=dir+cf.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space)     then dir=dir+Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir=dir-Vector3.new(0,1,0) end
            if dir.Magnitude>0 then dir=dir.Unit end
            root.Velocity=dir*S.FlySpeed; hum.PlatformStand=dir.Magnitude>0
        end
    else
        if player.Character then
            local hum=player.Character:FindFirstChild("Humanoid"); if hum then hum.PlatformStand=false end
        end
    end
    -- Tornado debris
    if S.Weather=="Tornado" then
        local camPos=Camera.CFrame.Position
        for _=1,2 do
            local db=Instance.new("Part"); db.Size=Vector3.new(0.5,0.5,0.5)
            db.Material=Enum.Material.SmoothPlastic; db.Color=Color3.fromRGB(105,105,85)
            db.CanCollide=false; db.Anchored=false
            local angle=tick()*3; local radius=math.random(8,28)
            db.Position=camPos+Vector3.new(math.cos(angle)*radius+math.random(-4,4),math.random(-8,18),math.sin(angle)*radius+math.random(-4,4))
            db.Parent=FXFolder
            local vel=Instance.new("BodyVelocity"); vel.Velocity=Vector3.new(math.cos(angle+1.5)*38,math.random(4,18),math.sin(angle+1.5)*38)
            vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=db; Debris:AddItem(db,1.4)
        end
    end
    -- Ash (Volcanic/Apocalypse)
    if S.Weather=="Volcanic" or S.Weather=="Apocalypse" then
        local camPos=Camera.CFrame.Position
        local ash=Instance.new("Part"); ash.Size=Vector3.new(0.4,0.4,0.4)
        ash.Material=Enum.Material.SmoothPlastic; ash.Color=Color3.fromRGB(40,30,25)
        ash.CanCollide=false; ash.Anchored=false; ash.Shape=Enum.PartType.Ball
        ash.Position=camPos+Vector3.new(math.random(-60,60),50,math.random(-60,60)); ash.Parent=FXFolder
        local vel=Instance.new("BodyVelocity"); vel.Velocity=Vector3.new(math.random(-3,3)*0.5,-25,math.random(-3,3)*0.5)
        vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=ash; Debris:AddItem(ash,3)
    end
end)

-- Meteor loop
RunService.Stepped:Connect(function(_,dt)
    if not S.Meteor then return end
    S.MeteorTimer=S.MeteorTimer+dt
    if S.MeteorTimer<1/math.max(0.01,S.MeteorRate) then return end
    S.MeteorTimer=0
    local camPos=Camera.CFrame.Position
    local spawnPos=camPos+Vector3.new(math.random(-160,160),math.random(90,160),math.random(-160,160))
    local target=camPos+Vector3.new(math.random(-40,40),-60,math.random(-40,40))
    local dir=(target-spawnPos).Unit
    local meteor=Instance.new("Part"); meteor.Size=Vector3.new(S.MeteorSize,S.MeteorSize*2.8,S.MeteorSize)
    meteor.Material=Enum.Material.Rock; meteor.Color=S.MeteorColor; meteor.CanCollide=false
    meteor.CFrame=CFrame.new(spawnPos,spawnPos+dir); meteor.Parent=workspace
    local fire=Instance.new("Fire",meteor); fire.Color=S.MeteorFireColor; fire.SecondaryColor=Color3.fromRGB(255,220,80); fire.Size=S.MeteorSize*3.5; fire.Heat=22
    local light=Instance.new("PointLight",meteor); light.Brightness=6; light.Range=S.MeteorSize*12; light.Color=fire.Color
    local vel=Instance.new("BodyVelocity"); vel.Velocity=dir*S.MeteorSpeed; vel.MaxForce=Vector3.new(9999,9999,9999); vel.Parent=meteor
    local impactDelay=(spawnPos-target).Magnitude/math.max(1,S.MeteorSpeed)+0.4
    task.delay(impactDelay,function()
        if meteor and meteor.Parent then
            if S.MeteorExplosions then
                local boom=Instance.new("Explosion"); boom.BlastRadius=S.MeteorRadius; boom.BlastPressure=0; boom.Position=meteor.Position; boom.Parent=workspace
                local ob=Lighting.Brightness; Lighting.Brightness=ob+2; task.delay(0.1,function() Lighting.Brightness=ob end)
            end
            meteor:Destroy()
        end
    end)
    Debris:AddItem(meteor,impactDelay+1)
end)

