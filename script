--  FPS / Ping counter
-- ============================================================
local frames=0; local lastT=tick()
RS.RenderStepped:Connect(function()
    frames=frames+1
    if tick()-lastT>=1 then
        pcall(function()
            local fText=tostring(frames).." fps"
            local ok,ping=pcall(function() return math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue()) end)
            local pText=(ok and tostring(ping) or "N/A").." ms"
            for _,lbl in ipairs(FPS_Labels)  do pcall(function() lbl.Text=fText end) end
            for _,lbl in ipairs(Ping_Labels) do pcall(function() lbl.Text=pText end) end
        end)
        frames=0; lastT=tick()
    end
end)

