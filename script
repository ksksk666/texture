local spawnT = 0
local function spawnSplash(px,py)
    for i=1,MAX_SPLASH do
        if not sData[i].active then
            sData[i]={active=true,x=px,y=py,t=0,maxT=0.3}; sFrames[i].Visible=true; return
        end
    end
end

local function resetDrop(i)
    local sw=RainGui.AbsoluteSize.X; local sh=RainGui.AbsoluteSize.Y
    local wr=math.rad(S.WindDir); local wm=(S.WindStr or 10)/80
    local d=dData[i]
    if rainType=="snow" then
        d.len=math.random(3,7); d.thick=math.random(3,6)
        d.vy=sh*(0.06+math.random()*0.08); d.vx=(math.cos(wr)*wm+(math.random()-0.5)*0.03)*sw
        d.alpha=0.25+math.random()*0.3
        dData[i]={active=true,x=math.random(-sw//4,sw+sw//4),y=-d.len,vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    elseif rainType=="sand" then
        d.len=math.random(5,12); d.thick=math.random(2,5)
        d.vy=sh*(0.06+math.random()*0.04); d.vx=(math.cos(wr)*wm*3+0.18)*sw
        d.alpha=0.35+math.random()*0.25
        dData[i]={active=true,x=-sw//4,y=math.random(0,sh),vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    else -- rain / acid
        local sp=(S.Weather=="Thunderstorm" or S.Weather=="Hurricane") and 1.5 or 1.0
        d.len=math.random(10,24); d.thick=math.random(10,18)/10
        d.vy=sh*(0.18+math.random()*0.28)*sp; d.vx=(math.cos(wr)*wm)*sw
        d.alpha=0.2+math.random()*0.28
        dData[i]={active=true,x=math.random(-sw//4,sw+sw//4),y=-d.len,vy=d.vy,vx=d.vx,len=d.len,thick=d.thick,alpha=d.alpha}
    end
end

local function updateRain(dt)
    local sw=RainGui.AbsoluteSize.X; local sh=RainGui.AbsoluteSize.Y
    if sw==0 or sh==0 then return end
    local rate=rainType=="snow" and 0.045 or 0.016
    local toSpawn=math.floor(S.WeatherDensity or 5)+(rainType=="rain" and 3 or 0)
    spawnT=spawnT+dt
    if spawnT>=rate then
        spawnT=0
        local n=0
        for i=1,MAX_DROPS do
            if not dData[i].active and n<toSpawn then resetDrop(i); n=n+1 end
        end
    end
    local wr=math.rad(S.WindDir); local wm=(S.WindStr or 10)/80
    local ang=math.deg(math.atan2(math.cos(wr)*wm*sw,(S.WeatherDensity or 5)*8))
    for i=1,MAX_DROPS do
        local d=dData[i]
        if d.active then
            d.x=d.x+d.vx*dt; d.y=d.y+d.vy*dt
            local f=dFrames[i]
            if d.y>sh+40 or d.x>sw*1.3 or d.x<-sw*0.3 then
                d.active=false; f.Visible=false
                if d.y>=sh-25 and d.y<=sh+40 and rainType=="rain" then spawnSplash(d.x,sh-2) end
            else
                f.Visible=true
                local rc=(rainType=="acid") and Color3.fromRGB(100,220,80) or Color3.fromRGB(178,212,255)
                if rainType=="snow" then
                    f.Size=UDim2.new(0,d.thick,0,d.thick)
                    f.Position=UDim2.new(0,math.floor(d.x-d.thick/2),0,math.floor(d.y-d.thick/2))
                    f.Rotation=0; f.BackgroundColor3=Color3.fromRGB(225,238,255)
                    f.BackgroundTransparency=1-d.alpha
                elseif rainType=="sand" then
                    f.Size=UDim2.new(0,d.len,0,d.thick)
                    f.Position=UDim2.new(0,math.floor(d.x),0,math.floor(d.y))
                    f.Rotation=0; f.BackgroundColor3=Color3.fromRGB(210,178,115)
                    f.BackgroundTransparency=1-d.alpha
                else
                    f.Size=UDim2.new(0,math.floor(d.thick*10)/10,0,d.len)
                    f.Position=UDim2.new(0,math.floor(d.x),0,math.floor(d.y))
                    f.Rotation=ang*0.6; f.BackgroundColor3=rc
                    f.BackgroundTransparency=1-d.alpha
                end
            end
        else dFrames[i].Visible=false end
    end
    for i=1,MAX_SPLASH do
        local sd=sData[i]
        if sd.active then
            sd.t=sd.t+dt; local prog=sd.t/sd.maxT
            if prog>=1 then sd.active=false; sFrames[i].Visible=false
            else
                local e=1-(1-prog)^2; local r=e*14; local a=(1-prog)*0.8
                local sf=sFrames[i]
                sf.Size=UDim2.new(0,r*2,0,r*0.45)
                sf.Position=UDim2.new(0,math.floor(sd.x-r),0,math.floor(sd.y-r*0.22))
                sf.Visible=true
                local inner=sf:FindFirstChild("Frame")
                if inner then
                    local stroke=inner:FindFirstChildOfClass("UIStroke")
                    if stroke then stroke.Transparency=1-a end
                end
            end
        end
    end
end

local function clearRain()
    rainActive=false; rainType="none"
    for i=1,MAX_DROPS do dData[i].active=false; dFrames[i].Visible=false end
    for i=1,MAX_SPLASH do sData[i].active=false; sFrames[i].Visible=false end
end

