SG.InputBegan:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1 and DropFrame.Visible then
        local mx,my=inp.Position.X,inp.Position.Y
        local ax,ay=DropFrame.AbsolutePosition.X,DropFrame.AbsolutePosition.Y
        local aw,ah=DropFrame.AbsoluteSize.X,DropFrame.AbsoluteSize.Y
        if mx<ax or mx>ax+aw or my<ay or my>ay+ah then CloseDropdown() end
    end
end)

local function OpenDropdown(anchor, options, lbl, cb)
    CloseDropdown(); DropLbl=lbl; DropCB=cb
    for _, opt in ipairs(options) do
        local b=N("TextButton",{
            Text="  "..opt,
            Size=UDim2.new(1,0,0,24),
            BackgroundColor3=Color3.fromRGB(20,20,20),
            TextColor3=C.TextSub, Font=Enum.Font.Gotham, TextSize=11,
            BorderSizePixel=0, AutoButtonColor=false, ZIndex=10000,
            TextXAlignment=Enum.TextXAlignment.Left,
        },DropInner)
        Corner(4,b)
        b.MouseEnter:Connect(function() Tw(b,{BackgroundColor3=Color3.fromRGB(32,32,32),TextColor3=C.Text}) end)
        b.MouseLeave:Connect(function() Tw(b,{BackgroundColor3=Color3.fromRGB(20,20,20),TextColor3=C.TextSub}) end)
        b.MouseButton1Click:Connect(function()
            if DropLbl then DropLbl.Text=opt end
            local f=DropCB; CloseDropdown(); if f then f(opt) end
        end)
    end
    local n=math.min(#options,8)
    local mh=n*25+8
    local mw=math.max(160,anchor.AbsoluteSize.X)
    DropFrame.Size=UDim2.new(0,mw,0,mh)
    local px=anchor.AbsolutePosition.X
    local py=anchor.AbsolutePosition.Y+anchor.AbsoluteSize.Y+3
    local sw=SG.AbsoluteSize.X; local sh=SG.AbsoluteSize.Y
    if px+mw>sw-5 then px=sw-mw-5 end
    if py+mh>sh-5 then py=anchor.AbsolutePosition.Y-mh-3 end
    DropFrame.Position=UDim2.new(0,px,0,py)
    DropFrame.Visible=true
end

